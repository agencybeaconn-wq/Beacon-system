{%- comment -%} _kitCasalTagMover — move tag KIT CASAL pro dentro do .cart-item__price-row {%- endcomment -%}
<script>
(function() {
  if (window._kitCasalTagMover) return;
  window._kitCasalTagMover = true;
  function moveKitTags() {
    document.querySelectorAll(".kit-casal-tag").forEach(function (tag) {
      var parent = tag.parentElement;
      if (!parent) return;
      var priceRow = parent.querySelector(".cart-item__price-row");
      if (priceRow && tag.parentElement !== priceRow) {
        var discounted = priceRow.querySelector(".cart-item__discounted-prices");
        if (discounted) discounted.insertAdjacentElement("afterend", tag);
        else priceRow.insertBefore(tag, priceRow.firstChild);
      }
    });
  }
  moveKitTags();
  document.addEventListener("DOMContentLoaded", moveKitTags);
  setInterval(moveKitTags, 500);
})();
</script>
