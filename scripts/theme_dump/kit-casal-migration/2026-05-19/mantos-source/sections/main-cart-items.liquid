        {
          "value": "shirt",
          "label": "Camisa"
        },
        {
          "value": "gift",
          "label": "Presente"
        },
        {
          "value": "trophy",
          "label": "Troféu"
        },
        {
          "value": "star",
          "label": "Estrela"
        },
        {
          "value": "ball",
