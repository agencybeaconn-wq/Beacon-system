{% comment %}
  Renders cart drawer

  Usage:
  {% render 'cart-drawer' %}
{% endcomment %}

{{ 'quantity-popover.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'cart-progress-bar.css' | asset_url | stylesheet_tag }}

<script src="{{ 'cart.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'quantity-popover.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'cart-progress-bar.js' | asset_url }}" defer="defer"></script>

<style>
  .drawer {
    visibility: hidden;
  }

  /* TORCIDA-LINE-ITEM-V2 */
  .cart-items {
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .cart-drawer-item.cart-item {
    display: flex;
    gap: 1.4rem;
    padding: 1.6rem 0;
    border-bottom: 1px solid rgba(0,0,0,0.08);
    align-items: flex-start;
  }
  .cart-drawer-item.cart-item:last-child { border-bottom: none; }
  .cart-drawer-item.cart-item.cart-item__nested-line {
    margin-left: 2.4rem;
    border-bottom: 1px dashed rgba(0,0,0,0.08);
    padding: 1rem 0;
  }
  .cart-item__media {
    flex: 0 0 9rem;
    width: 9rem;
  }
  .cart-item__image {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 8px;
    background: #f4f4f4;
  }
  .cart-item__body {
    flex: 1 1 auto;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .cart-item__head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 0.8rem;
  }
  .cart-item__name {
    font-size: 1.4rem;
    font-weight: 600;
    line-height: 1.3;
    color: #151515;
    text-decoration: none;
    flex: 1;
  }
  .cart-item__name:hover { text-decoration: underline; }
  .cart-item__remove .cart-remove-btn {
    background: transparent;
    border: 0;
    padding: 0.4rem;
    cursor: pointer;
    color: #888;
    line-height: 0;
  }
  .cart-item__remove .cart-remove-btn:hover { color: #d63838; }
  .cart-item__remove .svg-wrapper svg { width: 16px; height: 16px; }

  .cart-item__props {
    margin: 0.2rem 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .cart-item__prop {
    display: flex;
    gap: 0.4rem;
    font-size: 1.2rem;
    color: #555;
    line-height: 1.4;
  }
  .cart-item__prop dt {
    font-weight: 700;
    margin: 0;
    color: #151515;
  }
  .cart-item__prop dd {
    margin: 0;
    font-weight: 400;
    color: #555;
  }
  .cart-item__prop--custom dd { font-weight: 600; color: #151515; }
  .cart-item__qty-row {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    margin: 0.4rem 0;
  }
  .cart-item__qty-label {
    font-size: 1.2rem;
    font-weight: 700;
    color: #151515;
  }
  .cart-item__prop--name-number {
    flex-wrap: wrap;
  }
  .cart-item__prop--name-number .cart-item__nn-block {
    display: inline-flex;
    gap: 0.3rem;
  }
  .cart-item__prop--name-number .cart-item__nn-block dt {
    font-weight: 700;
  }
  .cart-item__prop--name-number .cart-item__nn-block dd {
    font-weight: 600;
    color: #151515;
  }
  .cart-item__prop--name-number .cart-item__nn-sep {
    color: #b0b0b0;
    margin: 0 0.4rem;
  }

  .cart-item__bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 0.6rem;
    gap: 0.8rem;
  }
  .cart-item__price-final {
    font-size: 1.5rem;
    font-weight: 700;
    color: #151515;
  }
  .cart-item__price-compare {
    font-size: 1.2rem;
    color: #999;
    margin-left: 0.4rem;
    text-decoration: line-through;
  }

  /* Quantity selector */
  .cart-item__qty {
    display: inline-flex;
    align-items: center;
    border: 1px solid #d0d0d0;
    border-radius: 999px;
    overflow: hidden;
    height: 3.2rem;
  }
  .cart-item__qty-btn {
    background: transparent;
    border: 0;
    width: 3rem;
    height: 100%;
    font-size: 1.6rem;
    font-weight: 600;
    cursor: pointer;
    color: #151515;
    transition: background 0.15s;
  }
  .cart-item__qty-btn:hover { background: #f0f0f0; }
  .cart-item__qty-display {
    min-width: 3rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    font-size: 1.4rem;
    font-weight: 600;
    color: #151515;
    user-select: none;
  }
  .cart-item__qty-locked {
    display: inline-flex;
    align-items: center;
    font-size: 1.3rem;
    font-weight: 600;
    color: #151515;
    padding: 0;
  }

  .cart-item__error { display: none; }
  .cart-item__error[hidden="false"] { display: flex; }

  /* Patch nested: indica visualmente que é um adicional da camisa */
  .cart-item--patch::before {
    content: "↳";
    position: absolute;
    left: -1.6rem;
    color: #888;
  }
  .discounts__discount {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background-color: #dcfce7;
    color: #15803d;
    font-weight: 700;
    font-size: 1.2rem;
    padding: 0.35rem 0.8rem;
    border-radius: 8px;
    margin: 0.4rem 0 0.2rem;
    list-style: none;
    width: fit-content;
  }
  .discounts__discount svg {
    width: 12px;
    height: 12px;
  }
  .discounts__discount path {
    fill: currentColor;
  }
  .cart-item--patch {
    position: relative;
    background: #fafafa;
  }
</style>

<cart-drawer class="drawer{% if cart == empty %} is-empty{% endif %}">
  <div id="CartDrawer" class="cart-drawer">
    <div id="CartDrawer-Overlay" class="cart-drawer__overlay"></div>
    <div
      class="drawer__inner color-{{ settings.cart_color_scheme }}"
      role="dialog"
      aria-modal="true"
      aria-label="{{ 'sections.cart.title' | t }}"
      tabindex="-1"
    >
      {%- if cart == empty -%}
        <div class="drawer__inner-empty">
          <div class="cart-drawer__warnings center{% if settings.cart_drawer_collection != blank %} cart-drawer__warnings--has-collection{% endif %}">
            <div class="cart-drawer__empty-content">
              <h2 class="cart__empty-text">Seu carrinho está vazio</h2>
              <button
                class="drawer__close"
                type="button"
                onclick="this.closest('cart-drawer').close()"
                aria-label="{{ 'accessibility.close' | t }}"
              >
                <span class="svg-wrapper">
                  {{- 'icon-close.svg' | inline_asset_content -}}
                </span>
              </button>
              <a href="{{ routes.root_url }}" class="button empty-cart-button">
                CONTINUAR COMPRANDO
              </a>

              {%- if shop.customer_accounts_enabled and customer == null -%}
                <p class="cart__login-title h3">{{ 'sections.cart.login.title' | t }}</p>
                <p class="cart__login-paragraph">
                  {{ 'sections.cart.login.paragraph_html' | t: link: routes.account_login_url }}
                </p>
              {%- endif -%}
            </div>
          </div>
          {%- if settings.cart_drawer_collection != blank -%}
            <div class="cart-drawer__collection">
              {% render 'card-collection', card_collection: settings.cart_drawer_collection, columns: 1 %}
            </div>
          {%- endif -%}
        </div>
      {%- endif -%}
      <div class="drawer__header">
        <h2 class="drawer__heading">{{ 'sections.cart.title' | t }}</h2>
        <button
          class="drawer__close"
          type="button"
          onclick="this.closest('cart-drawer').close()"
          aria-label="{{ 'accessibility.close' | t }}"
        >
          <span class="svg-wrapper">
            {{- 'icon-close.svg' | inline_asset_content -}}
          </span>
        </button>
      </div>
      <cart-drawer-items
        {% if cart == empty %}
          class=" is-empty"
        {% endif %}
      >
        <form
          action="{{ routes.cart_url }}"
          id="CartDrawer-Form"
          class="cart__contents cart-drawer__form"
          method="post"
        >
          <div id="CartDrawer-CartItems" class="drawer__contents js-contents">
            {% render 'cart-progress-bar' %}
            {%- if cart != empty -%}
              <div class="drawer__cart-items-wrapper">
                <ul class="cart-items list-unstyled" role="list" data-version="TORCIDA-LINE-ITEM-V3">
            {%- liquid
              assign total_savings = 0
            -%}
            {%- for item in cart.items -%}
              {%- liquid
                assign is_patch = false
                if item.properties['Posição'] != blank or item.product.title contains 'Patch'
                  assign is_patch = true
                endif

                assign is_personalized = false
                if item.properties['_pairing_id'] != blank or item.properties['Nome'] != blank or item.properties['Número'] != blank
                  assign is_personalized = true
                endif
                assign is_promo = false
                for d in item.line_level_discount_allocations
                  if d.amount > 0
                    assign is_promo = true
                  endif
                endfor
                if item.final_price < item.original_price
                  assign is_promo = true
                endif
                for opt in item.options_with_values
                  assign opt_name_lc = opt.name | downcase
                  assign opt_val_lc = opt.value | downcase | strip
                  if opt_name_lc == 'personalizar' or opt_name_lc contains 'customize'
                    if opt_val_lc contains 'personalizar' and opt_val_lc != 'não personalizar' and opt_val_lc != 'nao personalizar' and opt_val_lc != 'não' and opt_val_lc != 'nao'
                      assign is_personalized = true
                    endif
                    if opt_val_lc contains 'customize' and opt_val_lc != 'no customize' and opt_val_lc != 'do not customize'
                      assign is_personalized = true
                    endif
                  endif
                endfor

                assign item_compare_at = item.variant.compare_at_price
                if item_compare_at == blank or item_compare_at <= item.final_price
                  assign item_compare_at = item.original_price
                endif
                assign item_savings = item_compare_at | minus: item.final_price | times: item.quantity
                assign total_savings = total_savings | plus: item_savings
              -%}
              <li
                id="CartDrawer-Item-{{ item.index | plus: 1 }}"
                class="cart-drawer-item cart-item{% if is_patch %} cart-item--patch{% endif %}{% if is_personalized and is_patch == false %} cart-item--personalized{% endif %}{% if item.parent_relationship.parent != null %} cart-item__nested-line{% endif %}"
                data-index="{{ item.index | plus: 1 }}"
                data-pairing-id="{{ item.properties._pairing_id }}"
                data-item-title="{{ item.product.title | escape }}"
                data-is-patch="{{ is_patch }}"
                data-quantity="{{ item.quantity }}"
              >
                <div class="cart-item__media">
                  {% if item.image %}
                    <a href="{{ item.url }}" class="cart-item__link" tabindex="-1" aria-hidden="true">
                      <img
                        class="cart-item__image"
                        src="{{ item.image | image_url: width: 300 }}"
                        alt="{{ item.image.alt | escape }}"
                        loading="lazy"
                        width="120"
                        height="{{ 120 | divided_by: item.image.aspect_ratio | ceil }}"
                      >
                    </a>
                  {% endif %}
                </div>

                <div class="cart-item__body">
                  <div class="cart-item__head">
                    <a href="{{ item.url }}" class="cart-item__name">{{- item.product.title | escape -}}</a>
                    <cart-remove-button
                      id="CartDrawer-Remove-{{ item.index | plus: 1 }}"
                      data-index="{{ item.index | plus: 1 }}"
                      class="cart-item__remove"
                    >
                      <button type="button" class="cart-remove-btn" aria-label="{{ 'sections.cart.remove_title' | t: title: item.title | escape }}" data-variant-id="{{ item.variant.id }}">
                        <span class="svg-wrapper">{{- 'icon-remove.svg' | inline_asset_content -}}</span>
                      </button>
                    </cart-remove-button>
                  </div>

                  {%- comment -%} Linha 2: quantity selector (sempre após o t��tulo) {%- endcomment -%}
                  <div class="cart-item__qty-row">
                    <span class="cart-item__qty-label">Quantidade:</span>
                    {%- if is_personalized or is_patch or is_promo -%}
                      <div class="cart-item__qty-locked" aria-label="Quantidade: 1">
                        <span>1 un</span>
                      </div>
                      <input type="hidden" name="updates[]" value="{{ item.quantity }}" data-index="{{ item.index | plus: 1 }}">
                    {%- else -%}
                      <div class="cart-item__qty" data-cart-qty data-line-key="{{ item.key }}" data-line-index="{{ item.index | plus: 1 }}">
                        <button class="cart-item__qty-btn" type="button" data-action="minus" aria-label="Diminuir quantidade">−</button>
                        <span class="cart-item__qty-display" data-qty-display>{{ item.quantity }}</span>
                        <button class="cart-item__qty-btn" type="button" data-action="plus" aria-label="Aumentar quantidade">+</button>
                      </div>
                    {%- endif -%}
                  </div>

                  {%- comment -%} Properties: variant options + custom properties (Nome/Numero juntos) {%- endcomment -%}
                  {%- liquid
                    assign nome_val = item.properties['Nome']
                    assign numero_val = item.properties['Número']
                  -%}
                  {%- if item.product.has_only_default_variant == false or item.properties.size != 0 -%}
                    <dl class="cart-item__props">
                      {%- if item.product.has_only_default_variant == false -%}
                        {%- for option in item.options_with_values -%}
                          <div class="cart-item__prop">
                            <dt>{{ option.name }}:</dt>
                            <dd>{{ option.value }}</dd>
                          </div>
                        {%- endfor -%}
                      {%- endif -%}

                      {%- if nome_val != blank or numero_val != blank -%}
                        <div class="cart-item__prop cart-item__prop--name-number">
                          {%- if nome_val != blank -%}
                            <span class="cart-item__nn-block"><dt>Nome:</dt><dd>{{ nome_val }}</dd></span>
                          {%- endif -%}
                          {%- if nome_val != blank and numero_val != blank -%}
                            <span class="cart-item__nn-sep">/</span>
                          {%- endif -%}
                          {%- if numero_val != blank -%}
                            <span class="cart-item__nn-block"><dt>Número:</dt><dd>{{ numero_val }}</dd></span>
                          {%- endif -%}
                        </div>
                      {%- endif -%}

                      {%- for property in item.properties -%}
                        {%- assign pkey = property.first -%}
                        {%- assign pfirst = pkey | slice: 0 -%}
                        {%- if property.last != blank and pfirst != '_' and pkey != 'Nome' and pkey != 'Número' -%}
                          <div class="cart-item__prop cart-item__prop--custom">
                            <dt>{{ pkey }}:</dt>
                            <dd>
                              {%- if property.last contains '/uploads/' -%}
                                <a href="{{ property.last }}" class="link" target="_blank">{{ property.last | split: '/' | last }}</a>
                              {%- else -%}
                                {{ property.last }}
                              {%- endif -%}
                            </dd>
                          </div>
                        {%- endif -%}
                      {%- endfor -%}
                    </dl>
                  {%- endif -%}

                  <ul class="discounts list-unstyled" role="list">
                    {%- for discount in item.line_level_discount_allocations -%}
                      {%- if discount.amount > 0 -%}
                        <li class="discounts__discount">
                          {{- 'icon-discount.svg' | inline_asset_content -}}
                          {{ discount.discount_application.title }}
                        </li>
                      {%- endif -%}
                    {%- endfor -%}
                  </ul>

                  <div class="cart-item__bottom">
                    <div class="cart-item__price">
                      {%- if item_compare_at > item.final_price -%}
                        <strong class="cart-item__price-final">{{ item.final_price | money | replace: ' ', '' }}</strong>
                        <s class="cart-item__price-compare">{{ item_compare_at | money | replace: ' ', '' }}</s>
                      {%- else -%}
                        <strong class="cart-item__price-final">{{ item.final_price | money | replace: ' ', '' }}</strong>
                      {%- endif -%}
                    </div>
                  </div>

                  <div id="CartDrawer-LineItemError-{{ item.index | plus: 1 }}" class="cart-item__error" role="alert">
                    <small class="cart-item__error-text"></small>
                    <span class="svg-wrapper">{{- 'icon-error.svg' | inline_asset_content -}}</span>
                  </div>
                </div>
              </li>
            {%- endfor -%}
          </ul>
              </div>
            {%- endif -%}
            <p id="CartDrawer-LiveRegionText" class="visually-hidden" role="status"></p>
            <p id="CartDrawer-LineItemStatus" class="visually-hidden" aria-hidden="true" role="status">
              {{ 'accessibility.loading' | t }}
            </p>
          </div>
          <div id="CartDrawer-CartErrors" role="alert"></div>
        </form>
      </cart-drawer-items>
      <div class="drawer__footer">
        {%- if settings.show_cart_note -%}
          <details id="Details-CartDrawer">
            <summary>
              <span class="summary__title">
                {{ 'sections.cart.note' | t }}
                {{- 'icon-caret.svg' | inline_asset_content -}}
              </span>
            </summary>
            <cart-note class="cart__note field">
              <label class="visually-hidden" for="CartDrawer-Note">{{ 'sections.cart.note' | t }}</label>
              <textarea
                id="CartDrawer-Note"
                class="text-area text-area--resize-vertical field__input"
                name="note"
                placeholder="{{ 'sections.cart.note' | t }}"
              >{{ cart.note }}</textarea>
            </cart-note>
          </details>
        {%- endif -%}

        <!-- Start blocks -->
        <!-- Subtotals -->

        <div class="cart-drawer__footer" {{ block.shopify_attributes }}>
          {%- comment -%} SUBTOTAL removido em V3: sem desconto/compare na loja, redundante com TOTAL {%- endcomment -%}

          <!-- ============================================ -->
          <!-- BANNER VERDE COM CUPOM (aparece só se houver desconto) -->
          <!-- ============================================ -->
          {%- if cart.total_discount > 0 -%}
            {%- for discount in cart.discount_applications -%}
              <div style="
                background-color: #dcfce7;
                border-radius: 6px;
                padding: 1rem 1.4rem;
                margin: 1.2rem 0;
                display: flex;
                align-items: center;
                justify-content: space-between;
              ">
                <!-- Lado esquerdo: Ícone de tag + Nome do cupom -->
                <div style="display: flex; align-items: center; gap: 0.8rem; color: #15803d; font-weight: 600; font-size: 1.4rem;">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" style="flex-shrink: 0;">
                    <path d="M20.59 13.41l-7.17 7.17a2 2 0 01-2.83 0L2 12V2h10l8.59 8.59a2 2 0 010 2.82z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    <circle cx="7" cy="7" r="1" fill="currentColor"/>
                  </svg>
                  {{ discount.title }}
                </div>
                <!-- Lado direito: Valor do desconto -->
                <span style="color: #15803d; font-weight: 800; font-size: 1.5rem;">
                  -{{ discount.total_allocated_amount | money }}
                </span>
              </div>
            {%- endfor -%}
          {%- endif -%}

          <!-- ============================================ -->
          <!-- TOTAL (valor final) -->
          <!-- ============================================ -->
          <div class="totals" role="status" style="
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding-top: 1.5rem;
            margin-top: 1rem;
            border-top: 1px solid rgba(var(--color-foreground), 0.08);
          ">
            <h2 class="totals__total" style="margin: 0; text-transform: uppercase; font-weight: 800; font-size: 2.22rem; color: #151515;">TOTAL</h2>
            <p class="totals__total-value" style="margin: 0; font-weight: 900; font-size: 2.4rem; color: #151515;">{{ cart.total_price | money | replace: ' ', '' }}</p>
          </div>

          <!-- CTA -->
          <div class="cart__ctas" {{ block.shopify_attributes }} style="width: 100%; margin-top: 1.5rem;">
            <button type="button" id="yampi-checkout-btn-drawer" class="cart__checkout-button"
              onclick="yampiClick()"
              {% if cart == empty %}disabled{% endif %}
              style="width: 100%; display: flex; justify-content: center; align-items: center; text-align: center;">
              FINALIZAR COMPRA
            </button>
            <button
              type="button"
              class="link underlined-link"
              onclick="this.closest('cart-drawer').close()"
              style="margin-top: 1rem; width: 100%; margin-left: auto; margin-right: auto; display: block;"
            >
              Continuar comprando
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>

<script>
  (function () {
    if (window._torcidaCartQtyInit) return;
    window._torcidaCartQtyInit = true;

    var inFlight = false;

    function refreshCartDrawer() {
      var cd = document.querySelector('cart-drawer');
      if (!cd) return;
      if (typeof cd.getSectionsToRender !== 'function') {
        window.location.reload();
        return;
      }
      var sections = cd.getSectionsToRender().map(function (s) { return s.id; });
      fetch('/?sections=' + sections.join(','))
        .then(function (r) { return r.json(); })
        .then(function (json) {
          cd.classList.toggle('is-empty', !json);
          cd.renderContents({ sections: json });
        })
        .catch(function () { window.location.reload(); });
    }

    function changeQty(lineKey, lineIndex, newQty) {
      if (inFlight) return;
      inFlight = true;
      var body = lineKey ? { id: lineKey, quantity: newQty } : { line: lineIndex, quantity: newQty };
      fetch('/cart/change.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body)
      })
      .then(function (r) { return r.json(); })
      .then(function () { refreshCartDrawer(); })
      .catch(function () { window.location.reload(); })
      .finally(function () { inFlight = false; });
    }

    document.addEventListener('click', function (e) {
      var btn = e.target.closest && e.target.closest('.cart-item__qty-btn[data-action]');
      if (!btn) return;
      e.preventDefault();
      var wrap = btn.closest('[data-cart-qty]');
      if (!wrap) return;
      var lineKey = wrap.dataset.lineKey;
      var lineIndex = parseInt(wrap.dataset.lineIndex);
      var display = wrap.querySelector('[data-qty-display]');
      var current = display ? parseInt(display.textContent) || 1 : 1;
      var next = btn.dataset.action === 'plus' ? current + 1 : current - 1;
      if (next < 0) next = 0;
      // Optimistic UI
      if (display && next > 0) display.textContent = next;
      changeQty(lineKey, lineIndex, next);
    });
  })();
</script>

<script>
  (function () {
    if (window._torcidaCartSafetySplit) return;
    window._torcidaCartSafetySplit = true;

    var checking = false;

    function isPersonalizedItem(item) {
      var p = item.properties || {};
      if (p['_pairing_id'] || p['Nome'] || p['Número']) return true;
      // checa option Personalizar
      var opts = item.options_with_values || item.variant_options || [];
      if (Array.isArray(opts)) {
        for (var i = 0; i < opts.length; i++) {
          var o = opts[i];
          var name = (o.name || '').toLowerCase();
          var val = ((o.value || '') + '').toLowerCase().trim();
          if ((name === 'personalizar' || name.indexOf('customize') >= 0) &&
              val.indexOf('personalizar') >= 0 &&
              val !== 'não personalizar' && val !== 'nao personalizar' && val !== 'não' && val !== 'nao') {
            return true;
          }
        }
      }
      // fallback pelo variant title
      var vt = (item.variant_title || '').toLowerCase();
      if (vt.indexOf('/ personalizar') >= 0 && vt.indexOf('não personalizar') < 0 && vt.indexOf('nao personalizar') < 0) return true;
      return false;
    }

    function refreshCartDrawer() {
      var cd = document.querySelector('cart-drawer');
      if (cd && typeof cd.getSectionsToRender === 'function') {
        var sections = cd.getSectionsToRender().map(function (s) { return s.id; });
        return fetch('/?sections=' + sections.join(','))
          .then(function (r) { return r.json(); })
          .then(function (json) { cd.renderContents({ sections: json }); })
          .catch(function () { window.location.reload(); });
      }
      window.location.reload();
    }

    async function checkAndSplit() {
      if (checking) return;
      checking = true;
      try {
        var cartResp = await fetch('/cart.js');
        var cart = await cartResp.json();
        var didSplit = false;
        for (var i = 0; i < cart.items.length; i++) {
          var item = cart.items[i];
          if (item.quantity > 1 && isPersonalizedItem(item)) {
            var extra = item.quantity - 1;
            // 1) trava personalizada em qty=1
            await fetch('/cart/change.js', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ id: item.key, quantity: 1 })
            });
            // 2) adiciona N-1 sem properties (mesma variant)
            await fetch('/cart/add.js', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ id: item.variant_id, quantity: extra })
            });
            didSplit = true;
          }
        }
        if (didSplit) await refreshCartDrawer();
      } catch (e) {
        // silencia
      } finally {
        checking = false;
      }
    }

    document.addEventListener('DOMContentLoaded', checkAndSplit);
    // Cart drawer abrindo / re-renderizando
    document.addEventListener('cart:item:added', checkAndSplit);
    document.addEventListener('cart:item:updated', checkAndSplit);
    // Fallback: quando cart-drawer for re-rendered
    document.body.addEventListener('cart-drawer:opened', checkAndSplit);
  })();
</script>
</cart-drawer>
