{%- comment -%}
  PIX discount badge for product page.
  Accepts: product {Object}, block {Object}
{%- endcomment -%}

{%- liquid
  assign target = product.selected_or_first_available_variant
  assign price = target.price | default: 0
  assign pix_discount = block.settings.pix_discount | default: 5
  assign pix_discount_decimal = pix_discount | divided_by: 100.0
  assign pix_amount = price | times: pix_discount_decimal | round
  assign pix_price = price | minus: pix_amount
-%}

{%- if price > 0 -%}
  <div
    id="PixBadge-{{ section.id }}"
    class="pix-badge-block"
    data-base-price="{{ price }}"
    data-pix-discount="{{ pix_discount }}"
    style="border: 2px solid {{ block.settings.border_color }}; border-radius: 12px; padding: 1.2rem 1.6rem; display: flex; align-items: center; gap: 1.4rem; margin: 0 0 1.5rem; background-color: {{ block.settings.background_color }};"
    {{ block.shopify_attributes }}
  >
    <div
      aria-hidden="true"
      style="flex-shrink: 0; width: 48px; height: 48px; background-color: {{ block.settings.icon_color }}; border-radius: 10px; display: flex; align-items: center; justify-content: center;"
    >
      <svg fill="#ffffff" width="28px" height="28px" viewBox="0 0 16 16" xmlns="http://www.w3.org/2000/svg">
        <path d="M11.917 11.71a2.046 2.046 0 0 1-1.454-.602l-2.1-2.1a.4.4 0 0 0-.551 0l-2.108 2.108a2.044 2.044 0 0 1-1.454.602h-.414l2.66 2.66c.83.83 2.177.83 3.007 0l2.667-2.668h-.253zM4.25 4.282c.55 0 1.066.214 1.454.602l2.108 2.108a.39.39 0 0 0 .552 0l2.1-2.1a2.044 2.044 0 0 1 1.453-.602h.253L9.503 1.623a2.127 2.127 0 0 0-3.007 0l-2.66 2.66h.414z"/>
        <path d="m14.377 6.496-1.612-1.612a.307.307 0 0 1-.114.023h-.733c-.379 0-.75.154-1.017.422l-2.1 2.1a1.005 1.005 0 0 1-1.425 0L5.268 5.32a1.448 1.448 0 0 0-1.018-.422h-.9a.306.306 0 0 1-.109-.021L1.623 6.496c-.83.83-.83 2.177 0 3.008l1.618 1.618a.305.305 0 0 1 .108-.022h.901c.38 0 .75-.153 1.018-.421L7.375 8.57a1.034 1.034 0 0 1 1.426 0l2.1 2.1c.267.268.638.421 1.017.421h.733c.04 0 .079.01.114.024l1.612-1.612c.83-.83.83-2.178 0-3.008z"/>
      </svg>
    </div>

    <div style="flex: 1; min-width: 0;">
      <div style="display: flex; align-items: center; gap: 0.8rem; flex-wrap: wrap; line-height: 1.2;">
        <span
          class="pix-badge__price"
          style="font-size: 1.8rem; font-weight: 800; color: {{ block.settings.text_color }};"
        >{{- pix_price | money -}}</span>
        <span style="font-size: 1.4rem; font-weight: 500; color: {{ block.settings.text_color }};">no PIX</span>
        <span
          class="pix-badge__percent"
          style="background-color: {{ block.settings.badge_color }}; color: #ffffff; font-size: 1.2rem; font-weight: 700; padding: 0.2rem 0.7rem; border-radius: 20px; white-space: nowrap;"
        >-{{ pix_discount }}%</span>
      </div>
      <div style="font-size: 1.3rem; color: rgba(0,0,0,0.55); margin-top: 0.3rem;">
        Economize <span class="pix-badge__savings-amount">{{- pix_amount | money -}}</span> pagando no PIX
      </div>
    </div>
  </div>

  <script>
    (function () {
      var badge = document.getElementById('PixBadge-{{ section.id }}');
      if (!badge) return;

      var discount = parseFloat(badge.dataset.pixDiscount) / 100;

      function formatBRL(cents) {
        return 'R$\u00a0' + (cents / 100)
          .toFixed(2)
          .replace('.', ',')
          .replace(/\B(?=(\d{3})+(?!\d))/g, '.');
      }

      function updateBadge(price) {
        var savings = Math.round(price * discount);
        var pixPrice = price - savings;
        badge.querySelector('.pix-badge__price').textContent = formatBRL(pixPrice);
        badge.querySelector('.pix-badge__savings-amount').textContent = formatBRL(savings);
      }

      document.addEventListener('DOMContentLoaded', function () {
        var productInfo = document.querySelector('product-info[data-section="{{ section.id }}"]');
        if (!productInfo) return;
        productInfo.addEventListener('variantChange', function (e) {
          var variant = e.detail && e.detail.variant;
          if (variant && variant.price) updateBadge(variant.price);
        });
      });
    })();
  </script>
{%- endif -%}
