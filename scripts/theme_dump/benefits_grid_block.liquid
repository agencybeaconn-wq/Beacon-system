{%- when 'benefits_grid' -%}
                {{ 'component-shipping-calculator.css' | asset_url | stylesheet_tag }}
                <div class="benefits-grid-block quick-add-hidden" {{ block.shopify_attributes }}>
                  <div class="benefits-grid">
                    <div class="benefits-grid__item">
                      <span class="benefits-grid__icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
                      </span>
                      <div class="benefits-grid__text">
                        <strong>{{ block.settings.title_1 | default: 'Personalização Exclusiva' }}</strong>
                        <span>{{ block.settings.desc_1 | default: 'Adicione o nome e número do seu craque favorito.' }}</span>
                      </div>
                    </div>
                    <div class="benefits-grid__item">
                      <span class="benefits-grid__icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                      </span>
                      <div class="benefits-grid__text">
                        <strong>{{ block.settings.title_2 | default: 'Enviamos Para Todo o Brasil' }}</strong>
                        <span>{{ block.settings.desc_2 | default: 'Entrega segura com código de rastreio via Correios.' }}</span>
                      </div>
                    </div>
                    <div class="benefits-grid__item">
                      <span class="benefits-grid__icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-4.69"/></svg>
                      </span>
                      <div class="benefits-grid__text">
                        <strong>{{ block.settings.title_3 | default: '1ª Troca Grátis e Fácil' }}</strong>
                        <span>{{ block.settings.desc_3 | default: 'Errou o tamanho? A gente troca sem custo.' }}</span>
                      </div>
                    </div>
                    <div class="benefits-grid__item">
                      <span class="benefits-grid__icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                      </span>
                      <div class="benefits-grid__text">
                        <strong>{{ block.settings.title_4 | default: 'Qualidade Premium' }}</strong>
                        <span>{{ block.settings.desc_4 | default: 'Tecido leve, escudos bordados e acabamento de 1ª linha.' }}</span>
                      </div>
                    </div>
                  </div>
                </div>
              