        "use_cus_css": true,
        "code_cus_css": "\/* ===============================\n   SEÇÃO DOS JOGADORES — VERSÃO FINAL AJUSTADA (PC COMPACTO)\n   =============================== *\/\n.SectionID {\n  position: relative !important;\n}\n\n\/* Container principal do carrossel *\/\n.SectionID .t4s-collection-carousel {\n  display: flex !important;\n  gap: 0px !important; \/* 🔥 Remove quase todo o espaço entre jogadores *\/\n  justify-content: center !important;\n  flex-wrap: nowrap !important;\n  overflow-x: auto !important;\n  scroll-behavior: smooth !important;\n  background: transparent !important;\n  border: none !important;\n  box-shadow: none !important;\n  text-align: center;\n  padding: 0 !important;\n  margin: 0 !important;\n}\n\n\/* Itens *\/\n.SectionID .t4s-coll-img,\n.SectionID .t4s-coll-img .t4s_ratio {\n  flex: 0 0 auto !important;\n  width: 180px !important; \/* 🔥 Aumentado levemente o tamanho das imagens *\/\n  border-radius: 0 !important;\n  background: transparent !important;\n  overflow: visible !important;\n}\n\n\/* Imagens P&B com hover colorido *\/\n.SectionID .t4s-coll-img img {\n  display: block;\n  width: 100%;\n  height: auto;\n  object-fit: cover !important;\n  border: none !important;\n  background: transparent !important;\n  filter: grayscale(100%);\n  transition: filter 0.4s ease-in-out;\n}\n.SectionID .t4s-coll-img img:hover {\n  filter: grayscale(0%);\n}\n\n\/* Remove nome\/título abaixo *\/\n.SectionID .t4s-collection-title {\n  display: none !important;\n}\n\n\/* Hover com brilho *\/\n.SectionID:hover::before,\n.SectionID:hover::after {\n  filter: brightness(1.3);\n}\n\n\/* ===============================\n   RESPONSIVIDADE MOBILE\n   =============================== *\/\n@media (max-width: 768px) {\n  .SectionID .t4s-collection-carousel {\n    gap: 8px !important; \/* mantém espaçamento confortável no mobile *\/\n  }\n\n  .SectionID .t4s-coll-img,\n  .SectionID .t4s-coll-img .t4s_ratio {\n    width: 120px !important;\n  }\n\n  .SectionID::before {\n    left: 5px;\n    border-right: 16px solid #b42119;\n  }\n\n  .SectionID::after {\n    right: 5px;\n    border-left: 16px solid #b42119;\n  }\n}"
      }
