    "custom_liquid_yNwGyk": {
      "type": "custom-liquid",
      "name": "Custom Liquid",
      "settings": {
        "custom_liquid": "<div class=\"super-discounts-bar\">\n  <div class=\"super-discounts-content\">\n    <div class=\"left-section\">\n      <img \n        src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0644\/2486\/9961\/files\/icons8-relogio-despertador-96.png?v=1761589188\" \n        alt=\"Relógio\" \n        class=\"clock-icon\"\n      \/>\n      <div class=\"text-wrap\">\n        <strong>Ofertas da Semana!<\/strong>\n        <span class=\"offer-text offer-text-mobile\">48hrs de pura Oferta<\/span>\n      <\/div>\n    <\/div>\n    <div class=\"right-section\">\n      <span class=\"offer-text offer-text-desktop\">48hrs de pura Oferta<\/span>\n      <div id=\"daily-countdown\"><\/div>\n    <\/div>\n  <\/div>\n<\/div>\n\n<style>\n.super-discounts-bar {\n  width: 100%;\n  background: linear-gradient(90deg, #D32F2F 0%, #F26122 100%);\n  color: #fff;\n  font-family: 'Poppins', sans-serif;\n  box-sizing: border-box;\n}\n\n\/* 🔥 Layout geral *\/\n.super-discounts-content {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  padding: 6px 10px;\n  gap: 6px;\n  flex-wrap: nowrap;\n}\n\n\/* 🔹 Seção da esquerda *\/\n.left-section {\n  display: flex;\n  align-items: center;\n  gap: 6px;\n  min-width: 0;\n}\n\n.text-wrap {\n  display: flex;\n  flex-direction: column;\n  line-height: 1.2;\n  gap: 2px;\n  min-width: 0;\n}\n\n.left-section strong {\n  font-size: 13px;\n  font-weight: 700;\n  color: #fff;\n  white-space: nowrap;\n}\n\n.clock-icon {\n  width: 20px;\n  height: 20px;\n  flex-shrink: 0;\n}\n\n\/* 🔹 Seção da direita *\/\n.right-section {\n  display: flex;\n  align-items: center;\n  gap: 8px;\n  flex-shrink: 0;\n}\n\n.offer-text {\n  font-size: 10px;\n  font-weight: 500;\n  color: #fff;\n  white-space: nowrap;\n}\n\n.offer-text-desktop {\n  display: none;\n}\n\n.offer-text-mobile {\n  display: inline-block;\n}\n\n\/* 🔹 Contador *\/\n#daily-countdown {\n  display: flex;\n  align-items: center;\n  gap: 2px;\n  flex-shrink: 0;\n  white-space: nowrap;\n}\n\n.count-box {\n  background: #ffffff;\n  color: #333333;\n  font-weight: 700;\n  padding: 2px 4px;\n  border-radius: 5px;\n  display: inline-block;\n  min-width: 22px;\n  text-align: center;\n  font-size: 10px;\n  line-height: 1;\n}\n\n#daily-countdown span {\n  color: #ffffff;\n  font-weight: 700;\n  font-size: 10px;\n  line-height: 1;\n}\n\n\/* 💻 Desktop *\/\n@media (min-width: 769px) {\n  .super-discounts-content {\n    padding: 10px 24px;\n    gap: 12px;\n  }\n\n  .left-section {\n    gap: 10px;\n  }\n\n  .text-wrap {\n    flex-direction: row;\n    align-items: center;\n    gap: 8px;\n  }\n\n  .clock-icon {\n    width: 18px;\n    height: 18px;\n  }\n\n  .left-section strong {\n    font-size: 16px;\n  }\n\n  .right-section {\n    gap: 14px;\n  }\n\n  .offer-text {\n    font-size: 14px;\n  }\n\n  .offer-text-desktop {\n    display: inline-block;\n  }\n\n  .offer-text-mobile {\n    display: none;\n  }\n\n  .count-box {\n    padding: 5px 8px;\n    min-width: 34px;\n    font-size: 14px;\n  }\n\n  #daily-countdown span {\n    font-size: 14px;\n  }\n}\n<\/style>\n\n<script>\ndocument.addEventListener(\"DOMContentLoaded\", function() {\n  const countdownElement = document.getElementById(\"daily-countdown\");\n\n  function updateCountdown() {\n    const now = new Date();\n    const midnight = new Date();\n    midnight.setHours(24, 0, 0, 0);\n    const diff = midnight - now;\n\n    if (diff <= 0) return;\n\n    const hours = String(Math.floor((diff \/ (1000 * 60 * 60)) % 24)).padStart(2, \"0\");\n    const minutes = String(Math.floor((diff \/ (1000 * 60)) % 60)).padStart(2, \"0\");\n    const seconds = String(Math.floor((diff \/ 1000) % 60)).padStart(2, \"0\");\n\n    countdownElement.innerHTML = `\n      <div class=\"count-box\">${hours}<\/div>\n      <span>:<\/span>\n      <div class=\"count-box\">${minutes}<\/div>\n      <span>:<\/span>\n      <div class=\"count-box\">${seconds}<\/div>\n    `;\n  }\n\n  updateCountdown();\n  setInterval(updateCountdown, 1000);\n});\n<\/script>",
