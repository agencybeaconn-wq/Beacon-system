        "custom_liquid_GXLBpV": {
          "type": "custom_liquid",
          "settings": {
            "custom_liquid": "<style>\n  /* --- 1. Estilos da Barra de Destaques --- */\n  .trust-bar-container {\n    display: flex;\n    justify-content: space-between;\n    align-items: flex-start; /* Alinha no topo */\n    border-top: 1px solid #eeeeee;\n    border-bottom: 1px solid #eeeeee;\n    padding: 15px 0;\n    margin-top: 20px;\n    gap: 10px; /* Espaçamento entre os blocos */\n  }\n\n  .trust-block {\n    flex: 1; /* Faz os 3 blocos terem o mesmo tamanho */\n    display: flex;\n    align-items: center;\n    justify-content: flex-start;\n    padding: 5px;\n    cursor: pointer;\n    transition: background-color 0.2s;\n  }\n  \n  .trust-block:hover {\n    background-color: #f9f9f9;\n  }\n\n  .trust-block .icon {\n    flex-shrink: 0; /* Impede o ícone de encolher */\n    margin-right: 10px;\n  }\n  \n  /* Cor vermelha (#BC2020) para os ícones */\n  .trust-block .icon svg {\n    width: 28px;\n    height: 28px;\n    fill: #BC2020; \n  }\n\n  .trust-block .text-content .title {\n    display: block;\n    font-weight: 700;\n    font-size: 13px;\n    color: #333;\n  }\n\n  .trust-block .text-content .subtitle {\n    display: block;\n    font-size: 12px;\n    color: #777;\n    line-height: 1.3;\n  }\n  \n  /* Ajuste para telas pequenas (celular) */\n  @media (max-width: 600px) {\n    .trust-bar-container {\n        flex-direction: column; /* Fica vertical no celular */\n        align-items: flex-start;\n        gap: 15px;\n        padding-left: 10px;\n    }\n  }\n\n  /* --- 2. Estilos da Aba Lateral (Drawer) --- */\n  .drawer-overlay {\n    display: none; /* Começa escondido */\n    position: fixed;\n    top: 0;\n    left: 0;\n    width: 100%;\n    height: 100%;\n    background-color: rgba(0, 0, 0, 0.5);\n    z-index: 1000;\n  }\n\n  .drawer-panel {\n    display: none; /* Começa escondido */\n    position: fixed;\n    top: 0;\n    right: -100%; /* Começa fora da tela */\n    width: 320px; /* Largura da aba */\n    height: 100%;\n    background-color: #ffffff;\n    box-shadow: -2px 0 8px rgba(0,0,0,0.15);\n    z-index: 1001;\n    transition: right 0.3s ease-in-out;\n    display: flex;\n    flex-direction: column;\n  }\n\n  /* Classes para mostrar a aba */\n  .drawer-overlay.is-open,\n  .drawer-panel.is-open {\n    display: block;\n  }\n  .drawer-panel.is-open {\n    right: 0; /* Puxa para dentro da tela */\n  }\n  \n  /* Cabeçalho da Aba */\n  .drawer-header {\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    padding: 15px 20px;\n    border-bottom: 1px solid #e0e0e0;\n  }\n  \n  .drawer-header .drawer-title {\n    font-size: 18px;\n    font-weight: 700;\n    color: #333;\n  }\n  \n  .drawer-header .drawer-close {\n    background: none;\n    border: none;\n    font-size: 28px;\n    line-height: 1;\n    color: #888;\n    cursor: pointer;\n  }\n  \n  /* Conteúdo da Aba */\n  .drawer-content {\n    padding: 20px;\n    overflow-y: auto; /* Permite rolar se o texto for longo */\n    flex-grow: 1;\n    color: #555;\n    line-height: 1.6;\n  }\n  \n  .drawer-content h4 {\n    color: #333;\n    margin-top: 0;\n    margin-bottom: 15px;\n  }\n  \n  .drawer-content p {\n    font-weight: 400;\n  }\n  \n  .drawer-content p strong {\n     font-weight: 700;\n     color: #333;\n  }\n</style>\n\n<div class=\"trust-bar-container\">\n  \n  <div class=\"trust-block\" data-drawer-target=\"#drawer-garantia\">\n    <div class=\"icon\">\n      <!-- ÍCONE GARANTIA -->\n      <svg id=\"fi_4456988\" enable-background=\"new 0 0 512 512\" viewBox=\"0 0 512 512\" xmlns=\"http://www.w3.org/2000/svg\"><g><path d=\"m507.606 395.512-54.966-54.972c-5.668 11.929-16.509 21.095-30.264 24.363l-7.488 1.778-1.779 7.494c-3.039 12.799-17.333 36.901-47.42 34.455l-7.681-.624-4.006 6.575c-6.744 11.067-18.064 18.631-30.649 20.874l72.159 72.151c3.676 3.676 8.993 5.187 14.053 3.992 5.06-1.194 9.14-4.924 10.784-9.855l20.347-61.048 61.048-20.347c4.932-1.644 8.661-5.724 9.855-10.784 1.194-5.059-.317-10.377-3.993-14.052z\"></path><path d=\"m