-5.857 5.858-15.355 5.858-21.213 0l-32.316-32.315-24.231 24.231 67.154 67.153 107.32-107.32-24.231-24.231z\"></path></g></svg>\n    </div>\n    <div class=\"text-content\">\n      <span class=\"title\">Garantia de Qualidade</span>\n      <span class=\"subtitle\">Contra defeitos de fabricação.</span>\n    </div>\n  </div>\n\n  <div class=\"trust-block\" data-drawer-target=\"#drawer-entrega\">\n    <div class=\"icon\">\n      <!-- ÍCONE ENTREGA -->\n      <svg id=\"fi_5166970\" viewBox=\"0 0 512 512\" xmlns=\"http://www.w3.org/2000/svg\"><path d=\"m340.622 85.898-176.351 78.158 81.062 35.928 176.349-78.16z\"></path><path d=\"m137.948 152.39 176.352-78.158-60.323-26.732a21.333 21.333 0 0 0 -17.288 0l-167.7 74.327z\"></path><path d=\"m234.667 218.59-181.334-80.37v209.806a21.332 21.332 0 0 0 12.69 19.5l168.643 74.742z\"></path><path d=\"m256 362.667v79.605l22.855-10.13a116.684 116.684 0 0 1 -22.855-69.475z\"></path><path d=\"m373.333 245.333a116.611 116.611 0 0 1 64 19.067v-126.18l-181.333 80.37v144.077a117.466 117.466 0 0 1 117.333-117.334z\"></path><path d=\"m373.333 266.667a96 96 0 1 0 96 96 96 96 0 0 0 -96-96zm50.208 82.208-53.333 53.333a10.663 10.663 0 0 1 -15.083 0l-26.667-26.667a10.666 10.666 0 0 1 15.083-15.083l19.125 19.122 45.792-45.789a10.666 10.666 0 1 1 15.083 15.083z\"></path></svg>\n    </div>\n    <div class=\"text-content\">\n      <span class=\"title\">Entrega Rápida</span>\n      <span class=\"subtitle\">Enviamos para todo Brasil.</span>\n    </div>\n  </div>\n  \n  <div class=\"trust-block\" data-drawer-target=\"#drawer-seguranca\">\n    <div class=\"icon\">\n      <!-- ÍCONE SEGURANÇA -->\n      <svg version=\"1.1\" id=\"fi_666176\" xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 428.327 428.327\"><g><g><path d=\"M393.884,110.375c-0.512-11.264-0.512-22.016-0.512-32.768c0-8.483-6.877-15.36-15.36-15.36\n\t\t\tc-64,0-112.64-18.432-153.088-57.856c-5.973-5.854-15.531-5.854-21.504,0c-40.448,39.424-89.088,57.856-153.088,57.856\n\t\t\tc-8.483,0-15.36,6.877-15.36,15.36c0,10.752,0,21.504-0.512,32.768c-2.048,107.52-5.12,254.976,174.592,316.928l5.12,1.024\n\t\t\tl5.12-1.024C398.492,365.351,395.932,218.407,393.884,110.375z M201.884,259.367c-2.918,2.707-6.773,4.175-10.752,4.096h-0.512\n\t\t\tc-4.127-0.191-8.002-2.037-10.752-5.12l-47.616-52.736l23.04-20.48l37.376,41.472l82.944-78.848l20.992,22.528L201.884,259.367z\"></path></g></g></svg>\n    </div>\n    <div class=\"text-content\">\n      <span class=\"title\">Segurança Garantida</span>\n      <span class=\"subtitle\">Compra 100% segura.</span>\n    </div>\n  </div>\n  \n</div>\n\n<!-- DRAWERS -->\n<div class=\"drawer-overlay\" id=\"overlay-seguranca\"></div>\n<div class=\"drawer-panel\" id=\"drawer-seguranca\">\n  <div class=\"drawer-header\">\n    <span class=\"drawer-title\">Compra Segura</span>\n    <button class=\"drawer-close\" data-drawer-target=\"#drawer-seguranca\">&times;</button>\n  </div>\n  <div class=\"drawer-content\">\n    <h4>Seus Dados Estão Protegidos</h4>\n    <p>Utilizamos a tecnologia de pagamento da <strong>Appmax</strong>, uma das plataformas mais seguras e robustas do Brasil.</p>\n    <p>Seus dados de cartão de crédito são criptografados e não ficam armazenados em nossos servidores.</p>\n    <p>Além disso, nosso site possui certificado SSL (o cadeado no navegador), garantindo que sua navegação seja 100% segura.</p>\n  </div>\n</div>\n\n<div class=\"drawer-overlay\" id=\"overlay-entrega\"></div>\n<div class=\"drawer-panel\" id=\"drawer-entrega\">\n  <div class=\"drawer-header\">\n    <span class=\"drawer-title\">Nossa Entrega</span>\n    <button class=\"drawer-close\" data-drawer-target=\"#drawer-entrega\">&times;</button>\n  </div>\n  <div class=\"drawer-content\">\n    <h4>Enviamos para todo o Brasil</h4>\n    <p>Trabalhamos com os <strong>Correios</strong> para garantir que seu pedido chegue o mais rápido possível em qualquer lugar do país.</p>\n    <p>O prazo de entrega e o custo do frete podem ser calculados diretamente na página do carrinho, antes de você finalizar a compra.</p>\n  </div>\n</div>\n\n<div class=\"drawer-overlay\" id=\"overlay-garantia\"></div>\n<div class=\"drawer-panel\" id=\"drawer-garantia\">\n  <div class=\"drawer-header\">\n    <span class=\"drawer-title\">Garantia de Qualidade</span>\n    <button class=\"drawer-close\" data-drawer-target=\"#drawer-garantia\">&times;</button>\n  </div>\n  <div class=\"drawer-content\">\n    <h4>Qualidade Assegurada</h4>\n    <p>Oferecemos garantia total de <strong>7 dias</strong> contra defeitos de fabricação em todos os nossos produtos.</p>\n    <p>Caso receba um item com qualquer problema, basta entrar em contato por nossos canais de atendimento que realizaremos a troca sem custos.</p>\n    <p><i>*Lembre-se: Produtos personalizados não se aplicam à nossa política de devolução por arrependimento, mas a garantia contra defeitos é mantida.*</i></p>\n  </div>\n</div>\n\n<script>\n(function($) {\n  function abrirDrawer(targetID) {\n    $(targetID).addClass('is-open');\n    $(targetID).prev('.drawer-overlay').addClass('is-open'); \n  }\n  function fecharDrawer(targetID) {\n    $(targetID).removeClass('is-open');\n    $(targetID).prev('.drawer-overlay').removeClass('is-open');\n  }\n  $(document).ready(function() {\n    $('.trust-block').on('click', function() {\n      let targetID = $(this).data('drawer-target');\n      abrirDrawer(targetID);\n    });\n    $('.drawer-close').on('click', function() {\n      let targetID = $(this).data('drawer-target');\n      fecharDrawer(targetID);\n    });\n    $('.drawer-overlay').on('click', function() {\n      let targetID = '#' + $(this).next('.drawer-panel').attr('id'); \n      fecharDrawer(targetID);\n    });\n  });\n})(jQuery);\n</script>"
          }
