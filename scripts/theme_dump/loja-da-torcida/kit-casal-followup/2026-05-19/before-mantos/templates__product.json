          "disabled": true,
          "settings": {
            "custom_liquid": "{% comment %} \n  Aviso Geral de Recesso - Aparecerá em todos os produtos sem filtros.\n{% endcomment %}\n\n<div style=\"display: flex; align-items: center; justify-content: space-between; font-size: 17px; font-weight: 400; color: #121212; background-color: #FFF8E1; padding: 18px 20px; margin: 20px 0 30px 0; border-radius: 8px; border: 1px solid #FFD54F;\">\n  <div>\n    <div style=\"font-weight: 700; font-size: 16px; color: #1e1e1e; margin-bottom: 6px;\">AVISO IMPORTANTE</div>\n    <div style=\"font-size: 15px; line-height: 1.5;\">\n      Devido ao recesso do nosso fabricante de materiais, todos os pedidos realizados no site serão enviados a partir de <span style=\"font-weight: 700;\">24/02</span>.\n    </div>\n  </div>\n  <div style=\"flex-shrink: 0; margin-left: 12px;\">\n    {% comment %} Ícone de Alerta/Relógio condizente com o recesso {% endcomment %}\n    <svg width=\"42\" height=\"42\" viewBox=\"0 0 24 24\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n      <path d=\"M12 8V12L15 15\" stroke=\"#B26A00\" stroke-width=\"2\" stroke-linecap=\"round\"/>\n      <circle cx=\"12\" cy=\"12\" r=\"9\" stroke=\"#B26A00\" stroke-width=\"2\"/>\n    </svg>\n  </div>\n</div>"
          }
        },
