<style>
  /* Cards individuais arredondados, sem borders/linhas entre eles, separados por gap */
  .guarantees-accordion-wrapper {
    border: none !important;
    border-radius: 12px !important;
    background: #fff;
    margin: 0 0 8px 0 !important;
    overflow: hidden;
  }
  .guarantees-accordion-wrapper:first-of-type { margin-top: 12px !important; }
  .guarantees-accordion-wrapper:last-of-type { margin-bottom: 0 !important; }

  /* Hierarquia visual: título em negrito, subtítulo cinza menor */
  .guarantees-accordion-wrapper .guarantee-title {
    font-weight: 700;
    font-size: 16px;
    line-height: 1.35;
  }
  .guarantees-accordion-wrapper .guarantee-subtitle {
    font-weight: 400;
    color: #6b7280;
    font-size: 13.5px;
    line-height: 1.35;
  }

  /* Ícone solto — sem quadrado de fundo, só SVG colorido */
  .guarantees-accordion-wrapper .guarantee-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: auto;
    height: auto;
    background: transparent !important;
    flex-shrink: 0;
    margin-right: 12px;
    padding: 0;
  }
  .guarantees-accordion-wrapper .guarantee-icon svg {
    width: 24px;
    height: 24px;
    stroke-width: 2;
  }

  /* Cards BRANCOS no normal; WIPE FILL com cor sólida no HOVER (igual mecânica do botão Finalizar) */
  .guarantees-accordion-wrapper {
    background-size: 200% 100%;
    background-position: 100% 0;
    transition: background-position 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    cursor: pointer;
  }
  .guarantees-accordion-wrapper .guarantee-title,
  .guarantees-accordion-wrapper .guarantee-subtitle,
  .guarantees-accordion-wrapper .guarantee-arrow svg,
  .guarantees-accordion-wrapper .guarantee-icon svg {
    transition: color 0.3s ease, stroke 0.3s ease;
  }
  .guarantees-accordion-wrapper .guarantee-icon { transition: background 0.3s ease; }

  /* Centralizar conteúdo das bandeiras (mais pro centro) */
  .guarantees-accordion-wrapper .guarantee-header {
    padding-left: 16px;
    padding-right: 16px;
  }
  .guarantees-accordion-wrapper summary {
    padding: 14px 4px;
  }

  /* Texto da descrição expandida em NEGRITO + cor escura sólida */
  .guarantees-accordion-wrapper .guarantee-content {
    padding: 4px 16px 16px 64px;
    font-weight: 700 !important;
    color: #1f2937 !important;
    font-size: 13px;
    line-height: 1.5;
  }
  .guarantees-accordion-wrapper .guarantee-content p,
  .guarantees-accordion-wrapper .guarantee-content span,
  .guarantees-accordion-wrapper .guarantee-content * {
    font-weight: 700 !important;
    color: #1f2937 !important;
  }
  /* Hover: conteúdo vira branco junto com o card */
  .guarantees-accordion-wrapper:hover .guarantee-content,
  .guarantees-accordion-wrapper:hover .guarantee-content p,
  .guarantees-accordion-wrapper:hover .guarantee-content span,
  .guarantees-accordion-wrapper:hover .guarantee-content * {
    color: #ffffff !important;
  }

  /* PIX card — transparente com contorno forte (estilo Kit Casal — Pedro 2026-05-14) */
  .product__info-container .pix-discount-card {
    display: flex;
    align-items: center;
    gap: 12px;
    background: #ecfdf5;
    border: 2px solid #00b394;
    border-radius: 12px;
    padding: 11px 14px;
    margin: 10px 0 14px 0;
  }
  .product__info-container .pix-discount-card__logo-wrap {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    background: #00b394;
    border-radius: 10px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .product__info-container .pix-discount-card__logo {
    width: 32px;
    height: 32px;
  }
  .product__info-container .pix-discount-card__text {
    display: flex;
    flex-direction: column;
    line-height: 1.25;
  }
  .product__info-container .pix-discount-card__price {
    font-weight: 800;
    font-size: 18px;
    color: #047857;
  }
  .product__info-container .pix-discount-card__no-pix {
    font-weight: 500;
    font-size: 13px;
    color: #047857;
    margin-left: 2px;
  }
  .product__info-container .pix-discount-card__off {
    background: #00b394;
    color: #ffffff;
    border-radius: 4px;
    padding: 1px 6px;
    font-size: 11px;
    font-weight: 800;
    margin-left: 4px;
    display: inline-block;
    vertical-align: middle;
  }
  .product__info-container .pix-discount-card__save {
    font-size: 12px;
    color: #065f46;
    font-weight: 500;
    margin-top: 1px;
  }

  /* Setinha (chevron) do accordion das bandeiras — MAIOR pra parecer clicável */
  .product__info-container .guarantee-arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-left: auto;
    padding: 6px;
  }
  .product__info-container .guarantee-arrow svg {
    width: 18px !important;
    height: 18px !important;
    stroke-width: 2.5 !important;
    transition: transform 0.3s ease;
  }
  .product__info-container details[open] .guarantee-arrow svg {
    transform: rotate(180deg);
  }

    /* Cor 1 — Verde (Garantia) */
  .guarantees-color-1 { background-image: linear-gradient(to right, #16a34a 50%, #ffffff 50%) !important; }
  .guarantees-color-1 .guarantee-icon svg { color: #16a34a; stroke: #16a34a; }
  .guarantees-color-1:hover { background-position: 0 0 !important; }
  .guarantees-color-1:hover .guarantee-title,
  .guarantees-color-1:hover .guarantee-subtitle,
  .guarantees-color-1:hover .guarantee-arrow svg,
  .guarantees-color-1:hover .guarantee-icon svg { color: #ffffff !important; stroke: #ffffff !important; }

  /* Cor 2 — Azul (Entrega) */
  .guarantees-color-2 { background-image: linear-gradient(to right, #2563eb 50%, #ffffff 50%) !important; }
  .guarantees-color-2 .guarantee-icon svg { color: #2563eb; stroke: #2563eb; }
