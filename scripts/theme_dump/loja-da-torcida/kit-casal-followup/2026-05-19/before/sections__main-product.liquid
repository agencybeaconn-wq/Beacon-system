  .guarantees-color-2:hover .guarantee-arrow svg,
  .guarantees-color-2:hover .guarantee-icon svg { color: #ffffff !important; stroke: #ffffff !important; }

  /* Cor 3 — Laranja (Troca) */
  .guarantees-color-3 { background-image: linear-gradient(to right, #ea580c 50%, #ffffff 50%) !important; }
  .guarantees-color-3 .guarantee-icon svg { color: #ea580c; stroke: #ea580c; }
  .guarantees-color-3:hover { background-position: 0 0 !important; }
  .guarantees-color-3:hover .guarantee-title,
  .guarantees-color-3:hover .guarantee-subtitle,
  .guarantees-color-3:hover .guarantee-arrow svg,
  .guarantees-color-3:hover .guarantee-icon svg { color: #ffffff !important; stroke: #ffffff !important; }

  /* Cor 4 — Rosa (Suporte) */
  .guarantees-color-4 { background-image: linear-gradient(to right, #db2777 50%, #ffffff 50%) !important; }
  .guarantees-color-4 .guarantee-icon svg { color: #db2777; stroke: #db2777; }
