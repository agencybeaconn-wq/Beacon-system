{
    "css.lint.unknownAtRules": "ignore",
    "deno.enable": true,
    "deno.enablePaths": [
        "supabase/functions"
    ],
    "deno.importMap": "supabase/functions/import_map.json",
    "files.exclude": {
        "dist": true,
        "dist-ssr": true
    },
    "search.exclude": {
        "dist": true,
        "dist-ssr": true
    },

    "window.title": "Lever  ${separator}  ${rootName}  ${separator}  ${activeEditorMedium}${separator}${dirty}",
    "window.titleSeparator": " · ",

    "workbench.colorCustomizations": {
        "titleBar.activeBackground": "#050505",
        "titleBar.activeForeground": "#FFFFFF",
        "titleBar.inactiveBackground": "#0A0A0A",
        "titleBar.inactiveForeground": "#888888",
        "titleBar.border": "#DC2626",

        "activityBar.background": "#050505",
        "activityBar.foreground": "#FFFFFF",
        "activityBar.inactiveForeground": "#666666",
        "activityBar.activeBorder": "#DC2626",
        "activityBar.activeBackground": "#1A0606",
        "activityBarBadge.background": "#DC2626",
        "activityBarBadge.foreground": "#FFFFFF",

        "sideBar.background": "#0A0A0A",
        "sideBar.foreground": "#E5E5E5",
        "sideBar.border": "#1F1F1F",
        "sideBarTitle.foreground": "#FFFFFF",
        "sideBarSectionHeader.background": "#050505",
        "sideBarSectionHeader.foreground": "#DC2626",

        "statusBar.background": "#DC2626",
        "statusBar.foreground": "#FFFFFF",
        "statusBar.noFolderBackground": "#050505",
        "statusBar.debuggingBackground": "#7F1D1D",
        "statusBarItem.hoverBackground": "#B91C1C",
        "statusBarItem.remoteBackground": "#050505",
        "statusBarItem.remoteForeground": "#DC2626",

        "tab.activeBackground": "#1A1A1A",
        "tab.activeForeground": "#FFFFFF",
        "tab.activeBorderTop": "#DC2626",
        "tab.inactiveBackground": "#0A0A0A",
        "tab.inactiveForeground": "#888888",
        "tab.border": "#050505",
        "editorGroupHeader.tabsBackground": "#050505",

        "panel.background": "#0A0A0A",
        "panel.border": "#1F1F1F",
        "panelTitle.activeForeground": "#DC2626",
        "panelTitle.activeBorder": "#DC2626",

        "terminal.background": "#050505",
        "terminal.foreground": "#E5E5E5",
        "terminalCursor.foreground": "#DC2626",
        "terminal.selectionBackground": "#DC262640",
        "terminal.ansiRed": "#DC2626",
        "terminal.ansiBrightRed": "#EF4444",

        "button.background": "#DC2626",
        "button.foreground": "#FFFFFF",
        "button.hoverBackground": "#B91C1C",

        "focusBorder": "#DC2626",
        "list.activeSelectionBackground": "#1A0606",
        "list.activeSelectionForeground": "#FFFFFF",
        "list.inactiveSelectionBackground": "#0A0A0A",
        "list.hoverBackground": "#1A1A1A",

        "editor.background": "#0A0A0A",
        "editor.foreground": "#E5E5E5",
        "editor.selectionBackground": "#DC262630",
        "editor.lineHighlightBackground": "#1A1A1A",
        "editorCursor.foreground": "#DC2626",

        "scrollbarSlider.background": "#1F1F1F",
        "scrollbarSlider.hoverBackground": "#DC262660",
        "scrollbarSlider.activeBackground": "#DC2626",

        "badge.background": "#DC2626",
        "badge.foreground": "#FFFFFF",

        "notificationCenterHeader.background": "#050505",
        "notificationCenterHeader.foreground": "#DC2626"
    },

    "terminal.integrated.fontFamily": "JetBrains Mono, Cascadia Code, Consolas, monospace",
    "terminal.integrated.fontSize": 13,
    "terminal.integrated.cursorBlinking": true,
    "terminal.integrated.cursorStyle": "block"
}