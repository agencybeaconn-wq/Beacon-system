<style>
/* Patch Section Styles - Matching Kalles theme swatch style */

.patch-section-wrapper {
  margin-top: 0;
  margin-bottom: 20px;
}

.patch-section-header {
  margin-bottom: 0;
}

.patch-section-title {
  font-size: 14px;
  text-transform: uppercase;
  font-weight: 700;
  margin: 0.65em 0 1em;
  color: #000;
  padding: 0;
}

/* Container principal com borda 1px - estilo swatch */
.patch-section-container {
  border: 1px solid var(--border-sw-color, #e1e1e1);
  border-radius: 0;
  overflow: hidden;
  background-color: #fff;
}

.patch-section-toggle {
  padding: 12px 15px;
  background-color: #fff;
  cursor: pointer;
  display: flex;
  justify-content: space-between;
  align-items: center;
  transition: background-color 0.25s ease;
  border: none;
  border-radius: 0;
}

.patch-section-toggle:hover {
  background-color: #fafafa;
}

.patch-section-description {
  font-size: 14px;
  font-weight: 500;
  color: #666;
}

/* Accordion com transição suave - estilo swatch */
.patch-products-selector {
  padding: 0 15px;
  background-color: #fff;
  max-height: 0;
  overflow: hidden;
  opacity: 0;
  transition: max-height 0.35s cubic-bezier(0.4, 0, 0.2, 1), 
              opacity 0.25s ease,
              padding 0.35s ease;
}

.patch-products-selector.is-open {
  max-height: 2000px; /* Valor alto para acomodar conteúdo */
  opacity: 1;
  padding: 15px;
  border-top: 0;
}

.patch-arrow-down,
.patch-arrow-up {
  width: 20px;
  height: 20px;
  transition: transform 0.2s;
}

.patch-arrow-up {
  display: none;
}

.patch-position-section {
  margin-bottom: 20px;
}

.patch-position-section:last-child {
  margin-bottom: 0;
}

.patch-position-title {
  font-size: 13px;
  font-weight: 600;
  margin-bottom: 10px;
  text-transform: uppercase;
  color: #666;
}

.patch-position-patches {
  display: grid;
  grid-template-columns: 1fr;
  gap: 10px;
  width: 100%;
}

.patch-product-item {
  position: relative;
  width: 100%;
  height: 100%;
}

.patch-checkbox {
  position: absolute;
  opacity: 0;
  width: 0;
  height: 0;
}

.patch-product-item .block-swatch {
  width: 100%;
}

.patch-product-item label {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: flex-start;
  cursor: pointer;
  border: 1px solid var(--border-sw-color, #e1e1e1);
  border-radius: 0;
  padding: 10px;
  transition: color 0.4s cubic-bezier(0.4, 0, 0.2, 1), 
              border-color 0.4s cubic-bezier(0.4, 0, 0.2, 1),
              border-width 0.4s cubic-bezier(0.4, 0, 0.2, 1),
              font-weight 0.3s ease;
  height: 100%;
  width: 100%;
  box-sizing: border-box;
  background-color: #fff;
  text-align: left;
  min-height: auto;
}

.patch-product-item label:hover {
  color: var(--primary-sw-color, #222);
}

.patch-checkbox:checked + label,
.patch-product-item.selected label {
  border: 2px solid var(--primary-sw-color, #222);
  background-color: #fff;
  color: var(--text-color, #222);
  font-weight: 500;
}

.patch-product-content {
  display: flex;
  flex-direction: row;
  align-items: center;
  width: 100%;
  height: 100%;
}

.patch-product-image {
  width: 60px;
  height: 60px;
  object-fit: contain;
  margin-bottom: 0;
  margin-right: 15px;
}

.patch-product-info {
  margin-top: 0;
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: flex-start;
  width: 100%;
}

.patch-product-title {
  font-size: 11px;
  line-height: 1.3;
  margin-bottom: 2px;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  height: auto;
}

.patch-product-price {
  font-size: 12px;
  font-weight: 600;
  color: #666;
  margin-top: 0;
}

.patch-products-loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 20px;
}

/* Modern smooth spinner */
.patch-spinner {
  width: 24px;
  height: 24px;
  border: 2px solid #e1e1e1;
  border-top-color: #333;
  border-radius: 50%;
  animation: patch-spin 0.8s linear infinite;
}

@keyframes patch-spin {
  to {
    transform: rotate(360deg);
  }
}

/* Smooth loading state for buttons */
.patch-btn-loading {
  position: relative;
  pointer-events: none;
  opacity: 0.85;
  transition: opacity 0.2s ease;
}

.patch-btn-loading::after {
  content: '';
  position: absolute;
  width: 18px;
  height: 18px;
  top: 50%;
  left: 50%;
  margin-top: -9px;
  margin-left: -9px;
  border: 2px solid transparent;
  border-top-color: currentColor;
  border-radius: 50%;
  animation: patch-spin 0.7s linear infinite;
}

/* Smooth transitions for arrow icons */
.patch-arrows {
  display: flex;
  align-items: center;
  transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.patch-section-toggle[aria-expanded="true"] .patch-arrows {
  transform: rotate(180deg);
}

.patch-arrow-down,
.patch-arrow-up {
  transition: opacity 0.2s ease, transform 0.3s ease;
}

@media (max-width: 767px) {
  .patch-product-image {
    width: 50px;
    height: 50px;
    margin-right: 10px;
  }
  
  .patch-product-title {
    font-size: 10px;
  }
  
  .patch-product-price {
    font-size: 11px;
  }
}

/* Button loading state - SVG spinner animation */
.t4s-svg-spinner {
  animation: patch-spin 0.8s linear infinite;
}

.t4s-svg-spinner .t4s-path {
  stroke: currentColor;
  stroke-linecap: round;
  animation: t4s-dash 1.5s ease-in-out infinite;
}

@keyframes t4s-dash {
  0% {
    stroke-dasharray: 1, 150;
    stroke-dashoffset: 0;
  }
  50% {
    stroke-dasharray: 90, 150;
    stroke-dashoffset: -35;
  }
  100% {
    stroke-dasharray: 90, 150;
    stroke-dashoffset: -124;
  }
}

/* Success animation */
.t4s-btn-added,
.is-added {
  position: relative;
}

.t4s-btn-added::after,
.is-added::after {
  content: '✓';
  position: absolute;
  right: 15px;
  top: 50%;
  transform: translateY(-50%);
  font-size: 16px;
  animation: checkmark-pop 0.3s ease;
}

@keyframes checkmark-pop {
  0% {
    transform: translateY(-50%) scale(0);
    opacity: 0;
  }
  50% {
    transform: translateY(-50%) scale(1.2);
  }
  100% {
    transform: translateY(-50%) scale(1);
    opacity: 1;
  }
}

/* Dawn theme loading spinner compatibility */
.loading .loading__spinner,
.is-loading .loading__spinner {
  display: inline-block;
}

.loading__spinner {
  width: 1.5rem;
  height: 1.5rem;
}

.loading__spinner svg {
  animation: patch-spin 0.8s linear infinite;
}

/* Dawn button loading state */
button.loading,
button.is-loading {
  position: relative;
  pointer-events: none;
  opacity: 0.7;
}

button.loading::after,
button.is-loading::after {
  content: '';
  position: absolute;
  width: 16px;
  height: 16px;
  top: 50%;
  left: 50%;
  margin-top: -8px;
  margin-left: -8px;
  border: 2px solid transparent;
  border-top-color: currentColor;
  border-radius: 50%;
  animation: patch-spin 0.8s linear infinite;
}
</style>
