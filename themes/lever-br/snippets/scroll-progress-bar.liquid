{%- if target_id != blank -%}
  <div class="scroll-progress-bar-wrapper" id="prog-bar-{{ target_id }}">
    <div class="scroll-progress-track">
      <div class="scroll-progress-fill"></div>
    </div>
  </div>

  <style>
    /* Buttons will be hidden via Liquid or Scoped CSS to avoid global conflicts */

    #prog-bar-{{ target_id }} {
      width: 85% !important;
      margin-left: auto !important;
      margin-right: auto !important;
      height: 5px !important; /* Premium thickness */
      margin-top: 25px !important;
      margin-bottom: 25px !important;
      display: none !important; /* Hidden by default, script shows it */
      position: relative !important;
      background: rgba(0,0,0,0.05) !important; /* LIGHT GREY TRACK */
      border-radius: 10px !important;
      overflow: hidden !important;
      opacity: 0;
      transition: opacity 0.4s ease;
      z-index: 99 !important;
    }

    #prog-bar-{{ target_id }}.is-visible {
      display: block !important;
      opacity: 1 !important;
    }

    #prog-bar-{{ target_id }} .scroll-progress-fill {
      position: absolute !important;
      top: 0 !important;
      left: 0 !important;
      height: 100% !important;
      /* NEUTRAL COLOR - CUSTOMIZABLE VIA THEME SETTINGS */
      background-color: rgb(var(--color-button)) !important;
      background-image: none !important;
      border-radius: 10px !important;
      width: 0%; 
      z-index: 100 !important;
      will-change: width !important;
      display: block !important;
      transition: width 0.15s ease-out;
    }
  </style>

  <script>
    (function() {
      var initProgressBar = function() {
        var id = "{{ target_id }}";
        var el = document.getElementById(id);
        var bar = document.getElementById("prog-bar-" + id);
        if (!el || !bar) return;
        
        var fill = bar.querySelector(".scroll-progress-fill");
        
        function update() {
          if (!el || !fill || !bar) return;
          
          var sLeft = el.scrollLeft;
          var sWidth = el.scrollWidth;
          var cWidth = el.clientWidth;

          // Check for drag-based movements (transform fallback)
          var transform = window.getComputedStyle(el).transform;
          if (transform && transform !== 'none') {
             var m = transform.match(/matrix.*\((.+)\)/);
             if (m && m[1]) {
                var v = m[1].split(', ');
                var tx = Math.abs(parseFloat(v[v.length === 16 ? 12 : 4]));
                if (!isNaN(tx) && tx > 0) sLeft = tx;
             }
          }

          var max = sWidth - cWidth;
          if (max <= 1) {
             bar.classList.remove('is-visible');
             return;
          } else {
             bar.classList.add('is-visible');
          }
          
          var progress = Math.max(0, Math.min(1, sLeft / max));
          // Always show minimum 5% fill to indicate scrollable content
          var minFill = 5;
          var fillPercent = minFill + (progress * (100 - minFill));
          fill.style.width = fillPercent + '%';
        }
        
        // Polling for reactivity to drag components
        setInterval(update, 100);

        // Standard listeners
        el.addEventListener("scroll", update, { passive: true });
        if (window.ResizeObserver) {
          new ResizeObserver(update).observe(el);
          new ResizeObserver(update).observe(document.body);
        }
      };

      document.addEventListener("DOMContentLoaded", initProgressBar);
      document.addEventListener("shopify:section:load", initProgressBar);
      if (document.readyState !== 'loading') initProgressBar();
    })();
  </script>
{%- endif -%}
