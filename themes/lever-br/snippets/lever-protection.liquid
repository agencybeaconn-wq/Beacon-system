{%- assign license_key = settings.lever_license_key -%}

<script>
(function() {
  const licenseKey = "{{ license_key }}".trim();
  const currentShop = '{{ shop.permanent_domain }}'.trim();
  const supabaseUrl = "https://ykctllrqygchllhxnkjh.supabase.co/rest/v1/licenses";
  const anonKey = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InlrY3RsbHJxeWdjaGxsaHhua2poIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzAwNTU0NTIsImV4cCI6MjA4NTYzMTQ1Mn0.7xXWKBWVie2Hrwtuvavey73ys1NjNxSAcRE2JktJBw0";

  const isLocal = window.location.hostname === '127.0.0.1' || window.location.hostname === 'localhost';
  const isDesignMode = window.Shopify && window.Shopify.designMode;

  if (isLocal) return;

  function showOverlay(message, showInstructions) {
    var existing = document.getElementById('lever-license-overlay');
    if (existing) existing.remove();

    var overlay = document.createElement('div');
    overlay.id = 'lever-license-overlay';
    
    var instructionsHtml = '';
    if (isDesignMode && showInstructions) {
      instructionsHtml = '<div style="background:#f5f5f5;border-radius:8px;padding:15px 20px;text-align:left;margin-top:20px"><p style="font-size:14px;color:#333;margin:0 0 10px;font-weight:500">📋 Como ativar:</p><ol style="font-size:13px;color:#666;margin:0;padding-left:20px;line-height:1.8"><li>Acesse <strong>Configurações do tema</strong></li><li>Procure por <strong>"Beacon - Licença & Proteção"</strong></li><li>Insira sua chave de licença válida</li><li>Clique em <strong>Salvar</strong></li></ol></div>';
    }
    
    overlay.innerHTML = '<div style="position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(255,255,255,0.98);display:flex;justify-content:center;align-items:center;z-index:999999;font-family:-apple-system,BlinkMacSystemFont,Segoe UI,Roboto,sans-serif"><div style="text-align:center;padding:40px;max-width:500px"><div style="width:60px;height:60px;background:#121212;border-radius:12px;display:flex;align-items:center;justify-content:center;margin:0 auto 20px"><svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg></div><h1 style="font-size:24px;font-weight:600;color:#121212;margin:0 0 10px">Tema Beacon</h1><p style="font-size:16px;color:#666;margin:0 0 15px;line-height:1.5">' + message + '</p>' + instructionsHtml + (!showInstructions ? '<p style="font-size:14px;color:#999;margin:20px 0 0">Entre em contato com o suporte para obter sua licença.</p>' : '') + '<p style="font-size:12px;color:#999;margin:25px 0 0">Desenvolvido por <strong>Beacon</strong> | Shopify Partner</p></div></div>';
    document.body.appendChild(overlay);
  }

  function removeOverlay() {
    var overlay = document.getElementById('lever-license-overlay');
    if (overlay) overlay.remove();
  }

  async function validateLicense(attempt) {
    attempt = attempt || 1;
    
    if (!licenseKey) {
      showOverlay('Chave de licença não configurada.', true);
      return false;
    }

    try {
      var controller = new AbortController();
      var timeoutId = setTimeout(function() { controller.abort(); }, 8000);
      
      var response = await fetch(supabaseUrl + '?shop_url=eq.' + currentShop + '&license_key=eq.' + licenseKey + '&select=id,status', {
        method: 'GET',
        headers: {
          'apikey': anonKey,
          'Authorization': 'Bearer ' + anonKey,
          'Content-Type': 'application/json'
        },
        signal: controller.signal
      });
      
      clearTimeout(timeoutId);

      if (!response.ok) throw new Error('API Error');

      var data = await response.json();

      if (!data || data.length === 0 || data[0].status !== 'active') {
        showOverlay('Licença inválida, expirada ou domínio não autorizado.', false);
        return false;
      }
      
      removeOverlay();
      return true;

    } catch (error) {
      if (attempt < 3) {
        await new Promise(function(r) { setTimeout(r, 2000); });
        return validateLicense(attempt + 1);
      }
      
      if (isDesignMode) {
        removeOverlay();
        return true;
      }
      
      showOverlay('Erro na validação da licença.', true);
      return false;
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', function() { validateLicense(); });
  } else {
    validateLicense();
  }

  if (isDesignMode) {
    document.addEventListener('shopify:section:load', function() { validateLicense(); });
  }
})();
</script>
