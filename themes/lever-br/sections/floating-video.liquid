{{ 'section-video-stories.css' | asset_url | stylesheet_tag }}
<script src="{{ 'video-stories.js' | asset_url }}" defer="defer"></script>

{%- if section.settings.show_floating_video and section.settings.video_native != blank or section.settings.video_link != blank -%}
  <style>
    .floating-video-widget {
        --widget-width: {{ section.settings.widget_width_mobile }}px;
    }
    @media (min-width: 750px) {
        .floating-video-widget {
            --widget-width: {{ section.settings.widget_width_desktop }}px;
        }
    }
  </style>

  {%- assign video_native = section.settings.video_native -%}
  {%- assign video_link = section.settings.video_link -%}

  {%- comment -%} Determine video type and sources {%- endcomment -%}
  {%- assign video_type = '' -%}
  {%- assign shopify_video_src = '' -%}
  {%- assign shopify_video_type = '' -%}
  {%- assign custom_video_url = '' -%}
  {%- assign embed_video_url = '' -%}
  {%- assign final_cover_image = section.settings.image -%}

  {%- if video_native != blank -%}
      {%- assign video_type = 'shopify' -%}
      {%- for source in video_native.sources -%}
          {%- if source.format == 'mp4' -%}
              {%- assign shopify_video_src = source.url -%}
              {%- assign shopify_video_type = source.mime_type | default: 'video/mp4' -%}
              {%- break -%}
          {%- endif -%}
      {%- endfor -%}
      {%- if final_cover_image == blank -%}
          {%- assign final_cover_image = video_native.preview_image -%}
      {%- endif -%}
  {%- elsif video_link != blank -%}
      {%- if video_link contains 'youtube' or video_link contains 'youtu.be' -%}
          {%- assign video_type = 'youtube' -%}
          {%- assign embed_video_url = video_link -%}
      {%- elsif video_link contains 'vimeo' -%}
          {%- assign video_type = 'vimeo' -%}
          {%- assign embed_video_url = video_link -%}
      {%- else -%}
          {%- assign video_type = 'custom' -%}
          {%- assign custom_video_url = video_link -%}
      {%- endif -%}
  {%- endif -%}

  {%- comment -%} Determine the direct MP4 URL for inline autoplay {%- endcomment -%}
  {%- assign inline_video_url = '' -%}
  {%- if shopify_video_src != blank -%}
      {%- assign inline_video_url = shopify_video_src -%}
  {%- elsif custom_video_url != blank -%}
      {%- assign inline_video_url = custom_video_url -%}
  {%- endif -%}

  <div id="FloatingVideoWidget" class="floating-video-widget" style="position: fixed; bottom: {{ section.settings.bottom_offset }}px; left: {{ section.settings.left_offset }}px; z-index: 90; width: var(--widget-width); aspect-ratio: 9/16; filter: drop-shadow(0 10px 20px rgba(0,0,0,0.3)); cursor: pointer; transition: transform 0.3s ease, opacity 0.3s ease;">

    <div class="video-stories__item" style="width: 100%; height: 100%;">
      <button
        type="button"
        class="video-stories__button"
        data-video-type="{{ video_type }}"
        {% if video_type == 'shopify' %}
          data-shopify-video-src="{{ shopify_video_src }}"
          data-shopify-video-type="{{ shopify_video_type }}"
        {% elsif video_type == 'custom' %}
          data-custom-video-url="{{ custom_video_url }}"
        {% else %}
          data-video-url="{{ embed_video_url }}"
        {% endif %}
        aria-label="{{ section.settings.title | default: 'Assistir Vídeo' }}"
        style="width: 100%; height: 100%; padding: 0; border: none; background: none; position: relative;"
      >
        <div class="video-stories__thumbnail" style="width: 100%; height: 100%; aspect-ratio: 9/16; border-radius: 12px; overflow: hidden; position: relative; border: none; background: #000;">

            {%- comment -%} Inline autoplay video (muted) for MP4 sources {%- endcomment -%}
            {%- if inline_video_url != blank -%}
              <video autoplay muted loop playsinline class="video-stories__preview-video" style="width: 100%; height: 100%; object-fit: cover; position: absolute; top: 0; left: 0; z-index: 1;">
                <source src="{{ inline_video_url }}" type="video/mp4">
              </video>
            {%- elsif final_cover_image != blank -%}
              {{
                final_cover_image
                | image_url: width: 400
                | image_tag: loading: 'lazy', class: 'video-stories__image', style: 'width: 100%; height: 100%; object-fit: cover;'
              }}
            {%- else -%}
               <div class="video-stories__image-placeholder" style="width: 100%; height: 100%; background-size: cover; background-position: center;"></div>
            {%- endif -%}

            {%- comment -%} Subtle overlay — visible only on hover, or always for non-autoplay (YT/Vimeo) {%- endcomment -%}
            <div class="video-stories__overlay {% if inline_video_url != blank %}video-stories__overlay--subtle{% endif %}" style="position: absolute; top:0; left:0; width:100%; height:100%; display:flex; align-items:center; justify-content:center; background: rgba(0,0,0,0.1); z-index: 2;">
                <span class="video-stories__icon video-stories__icon--small" style="color: white !important; background: rgba(255, 255, 255, 0.25) !important; backdrop-filter: blur(12px) !important; -webkit-backdrop-filter: blur(12px) !important; border-radius: 50%; width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; border: 1.5px solid rgba(255, 255, 255, 0.45) !important; box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" class="icon-play" stroke="#fff" stroke-width="2" style="margin-left: 2px;">
                  <polygon points="5 3 19 12 5 21 5 3"></polygon>
                </svg>
              </span>
            </div>
        </div>
      </button>

      {%- comment -%} Botão Fechar dentro do widget {%- endcomment -%}
      <button type="button" onclick="document.getElementById('FloatingVideoWidget').style.display='none'; event.stopPropagation();" aria-label="Fechar" style="position: absolute; top: 10px; right: 10px; background: rgba(0,0,0,0.25); backdrop-filter: blur(4px); color: #fff; border: none; border-radius: 50%; width: 28px; height: 28px; display: flex; align-items: center; justify-content: center; cursor: pointer; z-index: 10001; transition: background 0.2s;">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>
  </div>

  <div id="VideoStoriesModal" class="video-stories-modal" aria-hidden="true">
      <button type="button" class="video-stories-modal__close" aria-label="Fechar">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
      <button type="button" class="video-stories-modal__mute" aria-label="Silenciar/Ativar Som">
        <svg class="icon-unmuted" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon>
          <line x1="19" y1="5" x2="19" y2="19"></line>
        </svg>
        <svg class="icon-muted hidden" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon>
          <line x1="23" y1="9" x2="17" y2="15"></line>
          <line x1="17" y1="9" x2="23" y2="15"></line>
        </svg>
      </button>
    <div class="video-stories-modal__content">
      <div class="video-stories-modal__video-container"></div>
    </div>
    <div class="video-stories-modal__backdrop"></div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Vídeo Flutuante",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_floating_video",
      "label": "Ativar Vídeo Flutuante",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Capa (Imagem)",
      "info": "Deixe em branco para buscar automaticamente (YouTube/Vimeo) ou usar a prévia do Vídeo Nativo."
    },
    {
      "type": "video",
      "id": "video_native",
      "label": "Vídeo Nativo (Shopify)",
      "info": "Selecione um vídeo dos arquivos da Shopify. Tem prioridade sobre o Link Externo."
    },
    {
      "type": "text",
      "id": "video_link",
      "label": "Link de Vídeo Externo",
      "info": "Suporta YouTube (Shorts/Padrão), Vimeo, MP4 ou links de arquivos Shopify. Usado se nenhum Vídeo Nativo for selecionado."
    },
    {
      "type": "header",
      "content": "Posição e Tamanho"
    },
    {
      "type": "range",
      "id": "widget_width_desktop",
      "min": 80,
      "max": 300,
      "step": 5,
      "unit": "px",
      "label": "Largura do Widget (Desktop)",
      "default": 160
    },
    {
      "type": "range",
      "id": "widget_width_mobile",
      "min": 60,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Largura do Widget (Mobile)",
      "default": 100
    },
    {
      "type": "range",
      "id": "bottom_offset",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Margem Inferior (Bottom)",
      "default": 20
    },
    {
      "type": "range",
      "id": "left_offset",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Margem Esquerda (Left)",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "Vídeo Flutuante"
    }
  ]
}
{% endschema %}
