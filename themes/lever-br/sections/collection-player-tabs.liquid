                    when 'bundesliga'
                      assign custom_team_image = 'https://pub-741e79c7a4b84c228594bbc296d1fbdd.r2.dev/Site%20Lever/Logos%20de%20Ligas/bundesliga.avif'
                    when 'liga-portugal'
