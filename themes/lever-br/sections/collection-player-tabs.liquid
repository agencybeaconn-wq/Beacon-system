{{ 'section-collection-list.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-slider.css' | asset_url | stylesheet_tag }}
{{ 'component-tabs.css' | asset_url | stylesheet_tag }}
{{ 'section-player-cards.css' | asset_url | stylesheet_tag }}

<script src="{{ 'section-tabs.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'slideshow-drag.js' | asset_url }}" defer="defer"></script>

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: 0 !important;
    padding-bottom: 0 !important; /* Fully consolidated spacing */
    --sliding-selector-unselected-text: {{ section.settings.unselected_tab_text_color }};
    --sliding-selector-active-text: {{ section.settings.active_tab_text_color }};
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: 0 !important;
      padding-bottom: 0 !important;
    }
  }

  /* Prevent cutting at bottom but keep tight */
  .collection-list-wrapper .grid__item {
      padding-bottom: 0 !important; 
  }

  .player-card-wrapper {
      margin-bottom: 0;
  }
  
  section-tabs {
      margin-top: -2.5rem !important;
      display: block;
  }

  /* Compact Slider Buttons Area and Wrapper */
  .slider-buttons {
      margin-top: -3.5rem !important; /* Extremely close as requested */
      margin-bottom: 0 !important;
      padding-bottom: 0 !important;
      position: relative;
      z-index: 2;
  }

  /* Pull next section closer */
  .collection-list-wrapper {
      margin-bottom: -1rem !important;
  }

  /* Better alignment for Mobile Sliders */
  @media screen and (max-width: 749px) {
    .section-{{ section.id }}-padding slider-component {
       padding: 0 !important;
    }
    
    .section-{{ section.id }}-padding .slider {
      padding-left: 0 !important;
      padding-right: 0 !important;
      margin-left: 0 !important;
      margin-right: 0 !important;
      width: 100% !important;
      scroll-padding-left: 0 !important; 
      scroll-padding-right: 0 !important;
      scroll-snap-type: x mandatory; 
      display: flex !important;
      flex-wrap: nowrap !important;
      column-gap: var(--grid-mobile-horizontal-spacing) !important;
      overflow-x: auto;
      scroll-behavior: smooth;
      -webkit-overflow-scrolling: touch !important;
    }

    .section-{{ section.id }}-padding .slider__slide {
      flex-shrink: 0 !important;
      scroll-snap-align: start;
    }

    .section-{{ section.id }}-padding slideshow-drag {
      display: block !important;
    }

    .section-{{ section.id }}-padding .slider__slide:first-child {
      margin-left: 0 !important;
    }
    
    /* Ensure columns without the peek displacement and perfect centering */
    .collection-list-wrapper .grid--2-col-tablet-down .grid__item {
        width: calc(50% - var(--grid-mobile-horizontal-spacing) / 2) !important;
        max-width: calc(50% - var(--grid-mobile-horizontal-spacing) / 2) !important;
        scroll-snap-align: start !important;
    }
  }

  .section-{{ section.id }}-padding .slider-buttons {
    margin-top: 2rem !important; /* Fixed overlapping negative margin */
    margin-bottom: 0 !important;
    padding-bottom: 0 !important;
    position: relative;
    z-index: 2;
    display: flex !important;
    visibility: visible !important;
    opacity: 1 !important;
  }
{%- endstyle -%}

{%- liquid
  assign columns_mobile_int = section.settings.columns_mobile | plus: 0
-%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="collection-list-wrapper page-width isolate section-{{ section.id }}-padding">
    <section-tabs>
        {%- if section.settings.title != blank -%}
          <div class="{% if section.settings.header_style == 'with_line' %}section-header--with-line section-header--{{ section.settings.header_alignment }}{% endif %}">
            <h2
              id="SectionHeading-{{ section.id }}"
              class="collection-list-title inline-richtext {{ section.settings.heading_size }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
              style="margin-bottom: 0; text-align: {{ section.settings.header_alignment }};"
            >
              {{ section.settings.title }}
            </h2>
          </div>
        {%- endif -%}

        {%- if section.settings.description != blank -%}
          <div class="collection__description {{ section.settings.description_style }} rte{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}" style="margin-bottom: 0; text-align: {{ section.settings.header_alignment }};">
            {{ section.settings.description -}}
          </div>
        {%- endif -%}

        {%- if category_blocks.size > 0 and player_blocks.size > 0 -%}
          {%- comment -%} Tab Navigation {%- endcomment -%}
          <div class="tabs-navigation tabs-navigation--{{ section.settings.header_alignment }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}" role="tablist" style="margin-bottom: 0; margin-top: 0; justify-content: {% if section.settings.header_alignment == 'left' %}flex-start{% elsif section.settings.header_alignment == 'right' %}flex-end{% else %}center{% endif %};">
            <button
              type="button"
              class="tabs-navigation__button tabs-navigation__button--active"
              data-tab-button="category-tab-{{ section.id }}"
              role="tab"
              aria-selected="true"
              aria-controls="TabPanel-category-{{ section.id }}"
            >
              {{ section.settings.category_tab_label }}
            </button>
            <button
              type="button"
              class="tabs-navigation__button"
              data-tab-button="player-tab-{{ section.id }}"
              role="tab"
              aria-selected="false"
              aria-controls="TabPanel-player-{{ section.id }}"
            >
              {{ section.settings.player_tab_label }}
            </button>
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} Category Tab Panel {%- endcomment -%}
      {%- liquid
        assign category_count = category_blocks.size
        assign show_mobile_slider_category = false
        if section.settings.swipe_on_mobile and category_count > columns_mobile_int
          assign show_mobile_slider_category = true
        endif
      -%}

      <div
        class="tabs-panel{% if category_blocks.size > 0 %} tabs-panel--active{% elsif player_blocks.size > 0 %} tabs-panel--hidden{% endif %}"
        data-tab-panel="category-tab-{{ section.id }}"
        id="TabPanel-category-{{ section.id }}"
        role="tabpanel"
        {% if category_blocks.size == 0 %}hidden{% endif %}
      >
        <slider-component class="slider-mobile-gutter{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
          <ul
            class="collection-list contains-card contains-card--collection{% if settings.card_style == 'standard' %} contains-card--standard{% endif %} grid grid--{{ section.settings.columns_desktop }}-col-desktop grid--{{ section.settings.columns_mobile }}-col-tablet-down{% if section.settings.swipe_on_mobile %} slider slider--tablet{% endif %}"
            id="Slider-category-{{ section.id }}"
            role="list"
          >
            {%- for block in category_blocks -%}
              <li
                id="Slide-category-{{ section.id }}-{{ forloop.index }}"
                class="grid__item{% if show_mobile_slider_category %} slider__slide{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
                {{ block.shopify_attributes }}
