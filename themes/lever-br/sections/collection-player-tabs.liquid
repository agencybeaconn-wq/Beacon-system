                      {{ card_image | image_url: width: 400 | image_tag: loading: 'lazy', widths: '200, 400, 600', class: 'player-card__image' }}
                    {%- elsif block.settings.custom_image_url != blank -%}
                      <img src="{{ block.settings.custom_image_url }}" alt="{{ card_title }}" loading="lazy" class="player-card__image">
                    {%- else -%}
                      {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
                    {%- endif -%}
                  </div>
                  <div class="player-card__info">
                    <h3 class="player-card__name">{{ card_title | default: "Nome da Categoria" }}</h3>
