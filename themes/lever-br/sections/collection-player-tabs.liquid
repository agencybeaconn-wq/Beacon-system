                <a href="{{ card_url | default: "#" }}" class="player-card-wrapper">
                  <div class="player-card__image-container">
                    {%- if custom_team_image != blank -%}
                      <img src="{{ custom_team_image }}" alt="{{ card_title }}" loading="lazy" class="player-card__image" style="object-fit: contain; padding: 10px;">
