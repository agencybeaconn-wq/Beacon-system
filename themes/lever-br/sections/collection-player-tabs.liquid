                    when 'italia'
                      assign custom_team_image = 'https://pub-741e79c7a4b84c228594bbc296d1fbdd.r2.dev/Site%20Lever/Logos%20Sele%C3%A7%C3%B5es/italia.webp'
                    when 'japao'
