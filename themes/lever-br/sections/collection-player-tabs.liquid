          </ul>
          {%- assign slider_id = 'Slider-category-' | append: section.id -%}
          {%- render 'scroll-progress-bar', target_id: slider_id -%}
          {%- liquid
            assign should_show_arrows_category = false
            if category_count > section.settings.columns_desktop and section.settings.show_desktop_arrows
              assign should_show_arrows_category = true
            elsif show_mobile_slider_category and section.settings.show_mobile_arrows
              assign should_show_arrows_category = true
            endif
          -%}
          {%- if should_show_arrows_category -%}
            <div class="slider-buttons{% if category_count > section.settings.columns_desktop %} no-js-hidden{% endif %}">
              <button type="button" class="slider-button slider-button--prev" name="previous" aria-label="{{ 'general.slider.previous_slide' | t }}">
                <span class="svg-wrapper">{{- 'icon-caret.svg' | inline_asset_content -}}</span>
              </button>
              <div class="slider-counter caption">
                <span class="slider-counter--current">1</span>
                <span aria-hidden="true"> / </span>
                <span class="visually-hidden">{{ 'general.slider.of' | t }}</span>
                <span class="slider-counter--total">{{ category_count }}</span>
              </div>
              <button type="button" class="slider-button slider-button--next" name="next" aria-label="{{ 'general.slider.next_slide' | t }}">
                <span class="svg-wrapper">{{- 'icon-caret.svg' | inline_asset_content -}}</span>
              </button>
            </div>
          {%- endif -%}
        </slider-component>
      </div>

      {%- comment -%} Player Tab Panel {%- endcomment -%}
      {%- liquid
        assign player_count = player_blocks.size
        assign show_mobile_slider_player = false
        if section.settings.swipe_on_mobile and player_count > columns_mobile_int
          assign show_mobile_slider_player = true
        endif
      -%}

      <div
        class="tabs-panel{% if category_blocks.size == 0 and player_blocks.size > 0 %} tabs-panel--active{% endif %}"
        data-tab-panel="player-tab-{{ section.id }}"
        id="TabPanel-player-{{ section.id }}"
        role="tabpanel"
        {% if category_blocks.size > 0 or player_blocks.size == 0 %}hidden{% endif %}
      >
        <slider-component class="slider-mobile-gutter{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
          <slideshow-drag>
            <ul
              class="grid grid--{{ section.settings.columns_desktop }}-col-desktop grid--{{ section.settings.columns_mobile }}-col-tablet-down{% if section.settings.swipe_on_mobile %} slider slider--tablet{% endif %} grid--player-cards"
              id="Slider-player-{{ section.id }}"
              role="list"
            >
              {%- for block in player_blocks -%}
                <li
                  id="Slide-player-{{ section.id }}-{{ forloop.index }}"
                  class="grid__item{% if show_mobile_slider_player %} slider__slide{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
                  {{ block.shopify_attributes }}
                >
                  {%- liquid
                    assign player_image = block.settings.player_image
                    assign player_name = block.settings.player_name
                    assign player_link = block.settings.player_link
                    
                    if block.settings.collection != blank and player_image == blank
                      assign player_image = block.settings.collection.featured_image
                    endif
                    if block.settings.collection != blank and player_name == blank
                      assign player_name = block.settings.collection.title
                    endif
                    if block.settings.collection != blank and player_link == blank
                      assign player_link = block.settings.collection.url
                    endif
                  -%}
                  <a href="{{ player_link | default: "#" }}" class="player-card-wrapper">
                    <div class="player-card__image-container">
                      {%- if player_image != blank -%}
                        {{ player_image | image_url: width: 400 | image_tag: loading: 'lazy', widths: '200, 400, 600', class: 'player-card__image' }}
                      {%- elsif block.settings.custom_image_url != blank -%}
                        <img src="{{ block.settings.custom_image_url }}" alt="{{ player_name }}" loading="lazy" class="player-card__image">
                      {%- else -%}
                        {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                      {%- endif -%}
                    </div>
                    <div class="player-card__info">
                      <h3 class="player-card__name">{{ player_name | default: "Nome do Jogador" }}</h3>
                      <span class="player-card__number">{{ block.settings.player_number }}</span>
                    </div>
                  </a>
                </li>
              {%- endfor -%}
            </ul>
            {%- assign slider_id = 'Slider-player-' | append: section.id -%}
            {%- render 'scroll-progress-bar', target_id: slider_id -%}
          </slideshow-drag>
          {%- liquid
            assign should_show_arrows_player = false
            if player_count > section.settings.columns_desktop and section.settings.show_desktop_arrows
              assign should_show_arrows_player = true
            elsif show_mobile_slider_player and section.settings.show_mobile_arrows
              assign should_show_arrows_player = true
            endif
          -%}
          {%- if should_show_arrows_player -%}
            <div class="slider-buttons{% if player_count > section.settings.columns_desktop %} no-js-hidden{% endif %}">
              <button type="button" class="slider-button slider-button--prev" name="previous" aria-label="{{ 'general.slider.previous_slide' | t }}">
                <span class="svg-wrapper">{{- 'icon-caret.svg' | inline_asset_content -}}</span>
              </button>
              <div class="slider-counter caption">
                <span class="slider-counter--current">1</span>
                <span aria-hidden="true"> / </span>
                <span class="visually-hidden">{{ 'general.slider.of' | t }}</span>
                <span class="slider-counter--total">{{ player_count }}</span>
              </div>
              <button type="button" class="slider-button slider-button--next" name="next" aria-label="{{ 'general.slider.next_slide' | t }}">
                <span class="svg-wrapper">{{- 'icon-caret.svg' | inline_asset_content -}}</span>
              </button>
            </div>
          {%- endif -%}
        </slider-component>
      </div>
    </section-tabs>
  </div>
</div>

