                    when 'cruzeiro'
                      assign custom_team_image = 'https://pub-741e79c7a4b84c228594bbc296d1fbdd.r2.dev/Site%20Lever/Logos%20Clubes/Brasileiros/cruzeiro%20(2).avif'
                    when 'botafogo'
                      assign custom_team_image = 'https://pub-741e79c7a4b84c228594bbc296d1fbdd.r2.dev/Site%20Lever/Logos%20Clubes/Brasileiros/fire%20(2).avif'
