<script>
  window.customPlayerRules = [
    {%- for block in section.blocks -%}
      {
        keywords: "{{ block.settings.keywords | downcase }}",
        excludeKeywords: "{{ block.settings.exclude_keywords | downcase }}",
        playerData: `
          {%- capture player_list -%}
            {%- for i in (1..15) -%}
              {%- assign name_key = 'player_name_' | append: i -%}
              {%- assign num_key = 'player_number_' | append: i -%}
              {%- assign p_name = block.settings[name_key] -%}
              {%- assign p_num = block.settings[num_key] -%}
              {%- if p_name != blank -%}
                {{ p_name }}|{{ p_num }}
                {%- unless forloop.last -%}\n{%- endunless -%}
              {%- endif -%}
            {%- endfor -%}
          {%- endcapture -%}
          {{ player_list | strip | strip_newlines }}
        `
      }{% unless forloop.last %},{% endunless %}
    {%- endfor -%}
  ];
  
  // Customization Price from settings (in cents)
  // Default to 300 cents (3.00) if not set
  window.customizationPrice = {{ section.settings.customization_price | default: 300 }};

  // Configurable disclaimer text
  window.customizationConfig = {
    disclaimer1: `{{ section.settings.disclaimer_1 | default: "Customized products cannot be exchanged, returned, or canceled;" | escape }}`,
    disclaimer2: `{{ section.settings.disclaimer_2 | default: "Orders with customized products have an additional delivery time of up to 6 days;" | escape }}`,
    disclaimer3: `{{ section.settings.disclaimer_3 | default: "The font used will be the same as observed in the official match line;" | escape }}`
  };
</script>

