                assign custom_team_image = 'https://pub-741e79c7a4b84c228594bbc296d1fbdd.r2.dev/Site%20Lever/Logos%20Clubes/Internacionais/17.webp'
              when 'chelsea'
                assign custom_team_image = 'https://pub-741e79c7a4b84c228594bbc296d1fbdd.r2.dev/Site%20Lever/Logos%20Clubes/Internacionais/zz.webp'
              when 'lyon' or 'olympique-lyon'
                assign custom_team_image = 'https://pub-741e79c7a4b84c228594bbc296d1fbdd.r2.dev/Site%20Lever/Logos%20Clubes/Internacionais/Lyon.png'
              when 'olympique-de-marseille' or 'marseille'
                assign custom_team_image = 'https://pub-741e79c7a4b84c228594bbc296d1fbdd.r2.dev/Site%20Lever/Logos%20Clubes/Internacionais/Marseille.png'
              when 'monaco' or 'as-monaco'
                assign custom_team_image = 'https://pub-741e79c7a4b84c228594bbc296d1fbdd.r2.dev/Site%20Lever/Logos%20Clubes/Internacionais/Monaco.png'
              when 'valencia' or 'valencia-1'
                assign custom_team_image = 'https://pub-741e79c7a4b84c228594bbc296d1fbdd.r2.dev/Site%20Lever/Logos%20Clubes/Internacionais/Valencia.png'
              when 'sevilla'
                assign custom_team_image = 'https://pub-741e79c7a4b84c228594bbc296d1fbdd.r2.dev/Site%20Lever/Logos%20Clubes/Internacionais/Sevilla.png'
              when 'ajax'
                assign custom_team_image = 'https://pub-741e79c7a4b84c228594bbc296d1fbdd.r2.dev/Site%20Lever/Logos%20Clubes/Internacionais/sssx.webp'
              when 'tottenham' or 'tottenham-hotspur'
                assign custom_team_image = 'https://pub-741e79c7a4b84c228594bbc296d1fbdd.r2.dev/Site%20Lever/Logos%20Clubes/Internacionais/a.webp'
              when 'roma' or 'rome'
                assign custom_team_image = 'https://pub-741e79c7a4b84c228594bbc296d1fbdd.r2.dev/Site%20Lever/Logos%20Clubes/Internacionais/k.webp'
              when 'la-liga' or 'laliga'
                assign custom_team_image = 'https://pub-741e79c7a4b84c228594bbc296d1fbdd.r2.dev/Site%20Lever/Logos%20de%20Ligas/LaLiga.avif'
              when 'premier-league'
                assign custom_team_image = 'https://pub-741e79c7a4b84c228594bbc296d1fbdd.r2.dev/Site%20Lever/Logos%20de%20Ligas/Premier%20League.avif'
              when 'brasileirao' or 'brasileiros' or 'brazilian-championship'
                assign custom_team_image = 'https://pub-741e79c7a4b84c228594bbc296d1fbdd.r2.dev/Site%20Lever/Logos%20de%20Ligas/brasileirao.avif'
              when 'bundesliga'
                assign custom_team_image = 'https://pub-741e79c7a4b84c228594bbc296d1fbdd.r2.dev/Site%20Lever/Logos%20de%20Ligas/bundesliga.avif'
              when 'ligue-1'
                assign custom_team_image = 'https://pub-741e79c7a4b84c228594bbc296d1fbdd.r2.dev/Site%20Lever/Logos%20de%20Ligas/ligue1.avif'
  when 'newcastle'
    assign custom_team_image = 'https://pub-741e79c7a4b84c228594bbc296d1fbdd.r2.dev/Site%20Lever/Logos%20Clubes/Internacionais/Newcastle.png'
  when 'newcastle-1'
    assign custom_team_image = 'https://pub-741e79c7a4b84c228594bbc296d1fbdd.r2.dev/Site%20Lever/Logos%20Clubes/Internacionais/Newcastle.png'
  when 'newcastle-united'
    assign custom_team_image = 'https://pub-741e79c7a4b84c228594bbc296d1fbdd.r2.dev/Site%20Lever/Logos%20Clubes/Internacionais/Newcastle.png'
  when 'real-betis'
    assign custom_team_image = 'https://pub-741e79c7a4b84c228594bbc296d1fbdd.r2.dev/Site%20Lever/Logos%20Clubes/Internacionais/Real%20Betis.png'
              endcase
            endif
          -%}
          {% render 'card-collection',
            card_collection: block.settings.collection,
            media_aspect_ratio: section.settings.image_ratio,
            columns: section.settings.columns_desktop,
            placeholder_image: placeholder_image,
            custom_image: block.settings.image,
            custom_image_url: custom_team_image
          %}
          </li>
        {%- endif -%}
      {%- endfor -%}
      
      {%- comment -%} Close last tab panel {%- endcomment -%}
      {%- if panel_open -%}
            </ul>
            {%- assign slider_id = 'Slider-' | append: section.id | append: '-' | append: tab_index -%}
            {%- render 'scroll-progress-bar', target_id: slider_id -%}
          </slideshow-drag>
            {%- liquid
              assign should_show_arrows = false
              if show_desktop_slider and section.settings.show_desktop_arrows
                assign should_show_arrows = true
              elsif show_mobile_slider and section.settings.show_mobile_arrows
                assign should_show_arrows = true
              endif
            -%}
            {%- if should_show_arrows -%}
              <div class="slider-buttons{% if show_desktop_slider and section.settings.show_desktop_arrows %} no-js-hidden{% endif %}">
                <button type="button" class="slider-button slider-button--prev" name="previous" aria-label="{{ 'general.slider.previous_slide' | t }}">
                  <span class="svg-wrapper">{{- 'icon-caret.svg' | inline_asset_content -}}</span>
                </button>
                <button type="button" class="slider-button slider-button--next" name="next" aria-label="{{ 'general.slider.next_slide' | t }}">
                  <span class="svg-wrapper">{{- 'icon-caret.svg' | inline_asset_content -}}</span>
                </button>
              </div>
            {%- endif -%}
          </slider-component>
        </div>
      {%- endif -%}
    </section-tabs>
  </div>
</div>

{% schema %}
{
  "name": "Coleções com Abas",
  "tag": "section",
  "class": "section section-collection-list",
  "max_blocks": 50,
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "select",
      "id": "header_style",
      "label": "Estilo do Cabeçalho",
      "options": [
        { "value": "standard", "label": "Padrão" },
        { "value": "with_line", "label": "Com Linha" }
      ],
      "default": "standard"
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "default": "Encontre o seu time",
      "label": "t:sections.collection-list.settings.title.label"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "t:sections.all.heading_size.options__1.label" },
        { "value": "h1", "label": "t:sections.all.heading_size.options__2.label" },
        { "value": "h0", "label": "t:sections.all.heading_size.options__3.label" },
        { "value": "hxl", "label": "t:sections.all.heading_size.options__4.label" },
        { "value": "hxxl", "label": "t:sections.all.heading_size.options__5.label" }
      ],
      "default": "h1",
      "label": "t:sections.all.heading_size.label"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Descrição"
    },
    {
      "type": "select",
      "id": "description_style",
      "label": "Estilo da descrição",
      "options": [
        { "value": "body", "label": "Corpo" },
        { "value": "subtitle", "label": "Subtítulo" },
        { "value": "uppercase", "label": "Maiúsculo" }
      ],
      "default": "body"
    },
    {
      "type": "select",
      "id": "header_alignment",
      "label": "Alinhamento do Cabeçalho",
      "options": [
        { "value": "left", "label": "Esquerda" },
        { "value": "center", "label": "Centro" },
        { "value": "right", "label": "Direita" }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "t:sections.collection-list.settings.header_layout.content"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "options": [
        { "value": "adapt", "label": "t:sections.collection-list.settings.image_ratio.options__1.label" },
        { "value": "portrait", "label": "t:sections.collection-list.settings.image_ratio.options__2.label" },
        { "value": "square", "label": "t:sections.collection-list.settings.image_ratio.options__3.label" }
      ],
      "default": "square",
      "label": "t:sections.collection-list.settings.image_ratio.label"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 6,
      "label": "Colunas no desktop",
      "info": "No mobile com carrossel, exibe 2 coleções por padrão"
    },
    {
      "type": "checkbox",
      "id": "enable_desktop_slider",
      "label": "Habilitar carrossel no desktop",
      "default": true
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "info": "t:sections.all.colors.has_cards_info",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.collection-list.settings.header_mobile.content"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "options": [
        { "value": "1", "label": "t:sections.collection-list.settings.columns_mobile.options__1.label" },
        { "value": "2", "label": "t:sections.collection-list.settings.columns_mobile.options__2.label" },
        { "value": "3", "label": "3 Colunas" }
      ],
      "default": "2",
      "label": "t:sections.collection-list.settings.columns_mobile.label"
    },
    {
      "type": "checkbox",
      "id": "swipe_on_mobile",
      "default": true,
      "label": "t:sections.collection-list.settings.swipe_on_mobile.label"
    },
    {
      "type": "header",
      "content": "Setas de Navegação"
    },
    {
      "type": "checkbox",
      "id": "show_desktop_arrows",
      "label": "Mostrar setas no desktop",
      "default": true,
      "info": "Exibe botões de navegação no desktop para sliders com múltiplos itens"
    },
    {
      "type": "checkbox",
      "id": "show_mobile_arrows",
      "label": "Mostrar setas no mobile",
      "default": false,
      "info": "Exibe botões de navegação no mobile para sliders com múltiplos itens"
    },
    {
      "type": "header",
      "content": "Cores das Abas"
    },
    {
      "type": "color",
      "id": "unselected_tab_text_color",
      "label": "Cor do Texto (Não Selecionado)",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "active_tab_text_color",
      "label": "Cor do Texto (Selecionado)",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "tab_header",
      "name": "Aba (Categoria)",
      "settings": [
        {
          "type": "text",
          "id": "tab_label",
          "label": "Título da Aba",
          "default": "Categoria"
        }
      ]
    },
    {
      "type": "collection_item",
      "name": "Coleção",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "t:sections.collection-list.blocks.featured_collection.settings.collection.label"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Imagem Personalizada",
          "info": "Selecione uma imagem para substituir a foto padrão da coleção"
        },
        {
          "type": "text",
          "id": "custom_image_url",
          "label": "URL da Imagem Personalizada",
          "info": "Aceita links externos (AVIF, WEBP, PNG). Deixe em branco para usar o logo padrão ou hardcodado."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Coleções com Abas",
      "blocks": [
        { "type": "tab_header", "settings": { "tab_label": "Seleções" } },
        { "type": "collection_item" },
        { "type": "collection_item" },
        { "type": "collection_item" },
        { "type": "tab_header", "settings": { "tab_label": "Clubes Brasileiros" } },
        { "type": "collection_item" },
        { "type": "collection_item" },
        { "type": "collection_item" }
      ]
    }
  ]
}
{% endschema %}
