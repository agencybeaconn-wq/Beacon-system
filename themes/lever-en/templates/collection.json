        "custom_liquid": "<section id=\"shopify-section-template--26574844363042__anuncio_rolante_yAKgdM\" class=\"shopify-section section-anuncio-rolante\"><!-- sections\/anuncio-rolante.liquid -->\n\n<div style=\"width: 100%; background-color: #000; overflow: hidden; padding: 8px 0;\" bis_skin_checked=\"1\">\n  <div style=\"\n    display: inline-block;\n    white-space: nowrap;\n    animation: scroll-left 15s linear infinite;\n    font-family: 'AdihausDIN Custom', sans-serif;\n    font-size: 13px;\n    color: #fff;\n    text-transform: uppercase;\n    letter-spacing: 1px;\n  \" bis_skin_checked=\"1\">\n    🎧 PROFESSIONAL SUPPORT &nbsp;&nbsp;&nbsp; 🔒 100% SECURE PURCHASE &nbsp;&nbsp;&nbsp; 📦 TRACKED SHIPPING &nbsp;&nbsp;&nbsp; FREE SHIPPING 🌍 WORLDWIDE &nbsp;&nbsp;&nbsp;\n    🎧 PROFESSIONAL SUPPORT &nbsp;&nbsp;&nbsp; 🔒 100% SECURE PURCHASE &nbsp;&nbsp;&nbsp; 📦 TRACKED SHIPPING &nbsp;&nbsp;&nbsp; FREE SHIPPING 🌍 WORLDWIDE &nbsp;&nbsp;&nbsp;\n    🎧 PROFESSIONAL SUPPORT &nbsp;&nbsp;&nbsp; 🔒 100% SECURE PURCHASE &nbsp;&nbsp;&nbsp; 📦 TRACKED SHIPPING &nbsp;&nbsp;&nbsp; FREE SHIPPING 🌍 WORLDWIDE &nbsp;&nbsp;&nbsp;\n    🎧 PROFESSIONAL SUPPORT &nbsp;&nbsp;&nbsp; 🔒 100% SECURE PURCHASE &nbsp;&nbsp;&nbsp; 📦 TRACKED SHIPPING &nbsp;&nbsp;&nbsp; FREE SHIPPING 🌍 WORLDWIDE &nbsp;&nbsp;&nbsp;\n  <\/div>\n<\/div>\n\n<style>\n  @keyframes scroll-left {\n    0% {\n      transform: translateX(0%);\n    }\n    100% {\n      transform: translateX(-50%);\n    }\n  }\n<\/style>\n\n\n<\/section>",
