      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<!-- PROMO BANNER: BUY 2 GET 3 — COLLECTION PAGE TOP -->\n\n<style>\n  .promo-banner-colecao {\n    width: 100%;\n    background: linear-gradient(135deg, #0a2e1a 0%, #0f4a28 50%, #0a2e1a 100%);\n    border-radius: 10px;\n    padding: 0;\n    margin-bottom: 28px;\n    overflow: hidden;\n    position: relative;\n    box-shadow: 0 4px 20px rgba(0, 163, 65, 0.18);\n  }\n\n  .promo-banner-colecao::before {\n    content: '';\n    position: absolute;\n    top: -40px;\n    right: -40px;\n    width: 180px;\n    height: 180px;\n    background: radial-gradient(circle, rgba(0, 220, 90, 0.18) 0%, transparent 70%);\n    pointer-events: none;\n  }\n\n  .promo-banner-colecao::after {\n    content: '';\n    position: absolute;\n    bottom: -30px;\n    left: 60px;\n    width: 120px;\n    height: 120px;\n    background: radial-gradient(circle, rgba(0, 220, 90, 0.10) 0%, transparent 70%);\n    pointer-events: none;\n  }\n\n  .promo-banner-colecao__inner {\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    padding: 18px 24px;\n    gap: 16px;\n    flex-wrap: wrap;\n  }\n\n  .promo-banner-colecao__left {\n    display: flex;\n    align-items: center;\n    gap: 14px;\n  }\n\n  .promo-banner-colecao__icon {\n    background: rgba(0, 220, 90, 0.15);\n    border: 1.5px solid rgba(0, 220, 90, 0.35);\n    border-radius: 50%;\n    width: 46px;\n    height: 46px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    flex-shrink: 0;\n    font-size: 20px;\n  }\n\n  .promo-banner-colecao__text {\n    display: flex;\n    flex-direction: column;\n    gap: 3px;\n  }\n\n  .promo-banner-colecao__title {\n    color: #ffffff;\n    font-size: 19px;\n    font-weight: 800;\n    letter-spacing: 0.5px;\n    line-height: 1.2;\n    text-transform: uppercase;\n    margin: 0;\n  }\n\n  .promo-banner-colecao__title span {\n    color: #00dc5a;\n  }\n\n  .promo-banner-colecao__sub {\n    color: rgba(255,255,255,0.65);\n    font-size: 15px;\n    margin: 0;\n    font-weight: 400;\n    letter-spacing: 0.2px;\n  }\n\n  .promo-banner-colecao__badge {\n    background: #00dc5a;\n    color: #042010;\n    font-size: 14px;\n    font-weight: 800;\n    letter-spacing: 1px;\n    text-transform: uppercase;\n    border-radius: 20px;\n    padding: 7px 18px;\n    white-space: nowrap;\n    box-shadow: 0 2px 12px rgba(0, 220, 90, 0.35);\n    animation: promo-pulse 2.5s ease-in-out infinite;\n  }\n\n  @keyframes promo-pulse {\n    0%, 100% { box-shadow: 0 2px 12px rgba(0, 220, 90, 0.35); }\n    50% { box-shadow: 0 2px 22px rgba(0, 220, 90, 0.6); }\n  }\n\n  .promo-banner-colecao__divider {\n    width: 1px;\n    height: 36px;\n    background: rgba(255,255,255,0.12);\n    flex-shrink: 0;\n  }\n\n  .promo-banner-colecao__steps {\n    display: flex;\n    align-items: center;\n    gap: 10px;\n    flex-wrap: wrap;\n  }\n\n  .promo-banner-colecao__step {\n    display: flex;\n    align-items: center;\n    gap: 6px;\n    color: rgba(255,255,255,0.75);\n    font-size: 14px;\n  }\n\n  .promo-banner-colecao__step-num {\n    background: rgba(0, 220, 90, 0.2);\n    color: #00dc5a;\n    border-radius: 50%;\n    width: 20px;\n    height: 20px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    font-size: 11px;\n    font-weight: 700;\n    flex-shrink: 0;\n  }\n\n  .promo-banner-colecao__arrow {\n    color: rgba(255,255,255,0.25);\n    font-size: 12px;\n  }\n\n  @media (max-width: 640px) {\n    .promo-banner-colecao__divider,\n    .promo-banner-colecao__steps {\n      display: none;\n    }\n    .promo-banner-colecao__inner {\n      padding: 14px 16px;\n    }\n  }\n<\/style>\n\n<div class=\"promo-banner-colecao\">\n  <div class=\"promo-banner-colecao__inner\">\n\n    <div class=\"promo-banner-colecao__left\">\n      <div class=\"promo-banner-colecao__icon\">⚽<\/div>\n      <div class=\"promo-banner-colecao__text\">\n        <p class=\"promo-banner-colecao__title\">Buy 2, <span>Get 3 Free<\/span><\/p>\n        <p class=\"promo-banner-colecao__sub\">Discount applied automatically at checkout<\/p>\n      <\/div>\n    <\/div>\n\n    <div class=\"promo-banner-colecao__divider\"><\/div>\n\n    <div class=\"promo-banner-colecao__steps\">\n      <div class=\"promo-banner-colecao__step\">\n        <span class=\"promo-banner-colecao__step-num\">1<\/span>\n        Pick 3 jerseys\n      <\/div>\n      <span class=\"promo-banner-colecao__arrow\">›<\/span>\n      <div class=\"promo-banner-colecao__step\">\n        <span class=\"promo-banner-colecao__step-num\">2<\/span>\n        Add to cart\n      <\/div>\n      <span class=\"promo-banner-colecao__arrow\">›<\/span>\n      <div class=\"promo-banner-colecao__step\">\n        <span class=\"promo-banner-colecao__step-num\">3<\/span>\n        Pay for 2 only!\n      <\/div>\n    <\/div>\n\n    <div class=\"promo-banner-colecao__badge\">🔥 Today only<\/div>\n\n  <\/div>\n<\/div>",
