<style>
  .payment-badges-section {
    margin-top: -1.5rem; /* Negative margin to pull it up to Add to Cart */
    margin-bottom: 2.5rem;
  }
  .payment-flags-container {
    text-align: center;
    margin-bottom: 0; 
    margin-top: 0;
  }
  .payment-options-header {
    text-align: center;
    margin-bottom: 2.8rem; /* Separates the link from the badges below */
    margin-top: -2.0rem; /* Glues the link to the flags image above */
  }
  .payment-options-trigger {
    display: inline-block;
    border-bottom: 1px solid currentColor;
    padding-bottom: 0;
    font-size: 1.3rem; 
    font-weight: 500;
    margin: 0;
    cursor: pointer;
    background: none;
    border: none;
    border-bottom: 1px solid #333;
    padding: 0 0 1px 0;
    font-family: inherit;
    color: inherit;
    line-height: 1.2;
  }
  .payment-badge-row {
    border: 1px solid #e5e5e5;
    padding: 1.2rem;
    margin-bottom: 0.8rem; /* Slightly tighter */
    border-radius: 12px;
    display: flex;
    align-items: center;
    gap: 1.5rem;
    background: #fff;
    min-height: 60px;
  }
  .payment-badge-logo {
    width: 60px; 
    height: auto;
    flex-shrink: 0;
    object-fit: contain;
  }
  .payment-badge-text {
    font-size: 1.3rem;
    line-height: 1.3;
    flex: 1;
    color: #333;
  }
  .payment-badge-link {
    font-size: 1.2rem;
    text-decoration: underline;
    color: #555;
    margin-left: 0.5rem;
    white-space: nowrap;
    cursor: pointer;
  }
  
  /* Trustpilot Row specific */
  .trustpilot-badge-row {
    justify-content: center;
    cursor: pointer;
    padding: 1.5rem;
    border-color: #000;
    background: #1c1c1c; 
    color: #fff;
  }
  .trustpilot-badge-row .tp-row-text {
    color: #fff; 
  }
  
  .tp-row-content {
      display: flex;
      align-items: center;
      gap: 0.8rem;
  }
  .tp-row-text {
      font-weight: 600;
      font-size: 1.4rem;
      color: #1a1a1a;
  }

  /* Modal/Popup Styles */
  .payment-modal {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background: rgba(0,0,0,0.5);
    z-index: 2147483647; 
    display: none;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s ease;
    padding: 20px;
    box-sizing: border-box;
  }
  .payment-modal.active {
    display: flex;
    opacity: 1;
    visibility: visible;
  }
  .payment-modal-content {
    background: #fff;
    padding: 2.5rem;
    border-radius: 12px;
    max-width: 500px;
    width: 100%;
    position: relative;
    text-align: center;
    box-shadow: 0 10px 40px rgba(0,0,0,0.3);
    transform: translateY(20px);
    transition: transform 0.3s ease;
  }
  .payment-modal.active .payment-modal-content {
    transform: translateY(0);
  }
  .payment-modal-close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    cursor: pointer;
    width: 30px;
    height: 30px;
    background: #f5f5f5;
    border-radius: 50%;
    border: none;
    color: #333;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
    padding: 0;
  }
  .payment-modal-close:hover {
      background: #e0e0e0;
  }
  .payment-modal-close svg {
      width: 14px;
      height: 14px;
      stroke: currentColor;
      stroke-width: 2;
  }
  .payment-modal-title {
    font-size: 1.8rem;
    margin-bottom: 2rem;
    font-weight: 600;
    color: #111;
  }
  .payment-modal-body {
    font-size: 1.4rem;
    line-height: 1.6;
    color: #555;
  }
</style>

<div class="payment-badges-section">
  <!-- Visible Payment Flags Image -->
  <div class="payment-flags-container">
      <img src="https://pub-741e79c7a4b84c228594bbc296d1fbdd.r2.dev/Site%20Lever/Badges/Bandeiras%20de%20Pagamentos.webp" 
           alt="Payment Methods" 
           loading="lazy"
           width="310"
           height="auto"
           style="width: 100%; max-width: 44rem; height: auto;">
  </div>

  <div class="payment-options-header">
    <button type="button" class="payment-options-trigger js-open-payment-modal" data-target="#PaymentModal-{{ section.id }}">
      More payment options
    </button>
  </div>

  <!-- PayPal -->
  {% if block.settings.show_paypal_badge %}
  <div class="payment-badge-row">
    <img src="https://pub-741e79c7a4b84c228594bbc296d1fbdd.r2.dev/Badges/paypal-logo-1-1.png" alt="PayPal" class="payment-badge-logo" style="width: auto; max-width: 80px; max-height: 25px;">
    <div class="payment-badge-text">
        Pay in 3 interest-free payments of <strong>{{ product.selected_or_first_available_variant.price | divided_by: 3.0 | money }}</strong>
        <a class="payment-badge-link js-open-payment-modal" data-target="#PayPalModal-{{ section.id }}">Learn more</a>
    </div>
  </div>
  {% endif %}

  <!-- Klarna -->
  {% if block.settings.show_klarna_badge %}
  <div class="payment-badge-row">
     <img src="https://pub-741e79c7a4b84c228594bbc296d1fbdd.r2.dev/Badges/Klarna_Payment_Badge.svg%20(1).png" alt="Klarna" class="payment-badge-logo" style="width: auto; max-width: 60px; max-height: 25px;">
     <div class="payment-badge-text">
        3 Payments of <strong>{{ product.selected_or_first_available_variant.price | divided_by: 3.0 | money }}</strong> at 0% interest with Klarna
        <a class="payment-badge-link js-open-payment-modal" data-target="#KlarnaModal-{{ section.id }}">Learn more</a>
     </div>
  </div>
  {% endif %}

  <!-- Trustpilot -->
  {% if block.settings.show_trustpilot_badge %}
  <div class="payment-badge-row trustpilot-badge-row" onclick="document.querySelector('.trustpilot-premium') ? document.querySelector('.trustpilot-premium').scrollIntoView({behavior: 'smooth'}) : null">
     <div class="tp-row-content">
        <span class="tp-row-text">Excellent</span>
        <!-- Stars -->
        <img src="https://pub-741e79c7a4b84c228594bbc296d1fbdd.r2.dev/Site%20Lever/Badges/Starts%20Trustpillot%20png.svg" style="height: 22px; width: auto;" alt="5 Stars">
        <!-- Logo -->
        <img src="https://pub-741e79c7a4b84c228594bbc296d1fbdd.r2.dev/Site%20Lever/Badges/NicePng_tilak-symbol-png_2561486.png" style="height: 22px; width: auto;" alt="Trustpilot">
     </div>
  </div>
  {% endif %}
</div>

<!-- Generic Payment Modal -->
<div id="PaymentModal-{{ section.id }}" class="payment-modal">
  <div class="payment-modal-content">
    <button type="button" class="payment-modal-close js-close-payment-modal" aria-label="Close">
         <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M18 6L6 18M6 6L18 18" stroke="currentColor" stroke-linecap="round"/>
        </svg>
    </button>
    <h3 class="payment-modal-title">Payment Methods</h3>
    
    <div style="text-align: center;">
         <img src="https://pub-741e79c7a4b84c228594bbc296d1fbdd.r2.dev/Site%20Lever/Badges/Bandeiras%20de%20Pagamentos.webp" 
           alt="Payment Methods" 
           loading="lazy"
           width="310"
           height="auto"
           style="width: 100%; height: auto;">
         
         <p style="margin-top: 1.5rem; font-size: 1.4rem; color: #555;">
           We accept all major credit cards and secure payment methods. Your transaction is encrypted and secure.
         </p>
    </div>
  </div>
</div>

<!-- PayPal Modal -->
<div id="PayPalModal-{{ section.id }}" class="payment-modal">
  <div class="payment-modal-content">
    <button type="button" class="payment-modal-close js-close-payment-modal" aria-label="Close">
         <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M18 6L6 18M6 6L18 18" stroke="currentColor" stroke-linecap="round"/>
        </svg>
    </button>
    <img src="https://pub-741e79c7a4b84c228594bbc296d1fbdd.r2.dev/Badges/paypal-logo-1-1.png" alt="PayPal" style="width: 100px; margin-bottom: 1.5rem;">
    <h3 class="payment-modal-title" style="margin-bottom: 1rem;">Pay in 3</h3>
    <div class="payment-modal-body">
      <p>Choose Pay in 3 at checkout where PayPal is available, and enjoy the power to split your purchase into three interest-free payments, with no set up fees or charges.*</p>
      <p style="font-size: 1.2rem; margin-top: 1rem; color: #999;">*Subject to status. Terms and conditions apply.</p>
    </div>
  </div>
</div>

<!-- Klarna Modal -->
<div id="KlarnaModal-{{ section.id }}" class="payment-modal">
  <div class="payment-modal-content">
    <button type="button" class="payment-modal-close js-close-payment-modal" aria-label="Close">
         <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M18 6L6 18M6 6L18 18" stroke="currentColor" stroke-linecap="round"/>
        </svg>
    </button>
    <img src="https://pub-741e79c7a4b84c228594bbc296d1fbdd.r2.dev/Badges/Klarna_Payment_Badge.svg%20(1).png" alt="Klarna" style="width: 80px; margin-bottom: 1.5rem;">
    <h3 class="payment-modal-title" style="margin-bottom: 1rem;">Shop now, Pay later</h3>
    <div class="payment-modal-body">
      <p>Split your purchase into 3 interest-free payments so you can spread the cost of your purchase over time. Enter your credit or debit card details and make automatic payments every 30 days.</p>
       <p style="font-size: 1.2rem; margin-top: 1rem; color: #999;">*Terms and conditions apply.</p>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
      const triggers = document.querySelectorAll('.js-open-payment-modal');
      const closeBtns = document.querySelectorAll('.js-close-payment-modal');
      const modals = document.querySelectorAll('.payment-modal');

      // Move all modals to body to avoid z-index/overflow issues
      modals.forEach(modal => {
        document.body.appendChild(modal);
        
        // Close on click outside
        modal.addEventListener('click', function(e) {
            if (e.target === modal) {
                modal.classList.remove('active');
            }
        });
      });

      // Open Modal Logic
      triggers.forEach(trigger => {
          trigger.addEventListener('click', function(e) {
              e.preventDefault();
              const targetId = this.getAttribute('data-target');
              const targetModal = document.querySelector(targetId);
              if (targetModal) {
                  // Close any open modals first
                  modals.forEach(m => m.classList.remove('active'));
                  targetModal.classList.add('active');
              }
          });
      });

      // Close Button Logic
      closeBtns.forEach(btn => {
          btn.addEventListener('click', function(e) {
              e.preventDefault();
              const modal = this.closest('.payment-modal');
              if (modal) {
                  modal.classList.remove('active');
              }
          });
      });
  });
</script>
