                      <tr><td>Recommended Height (cm)</td><td>162–170</td><td>170–176</td><td>176–182</td><td>182–190</td><td>190–195</td><td>195–197</td><td>197–200</td></tr>
                      <tr><td>Recommended Weight (kg)</td><td>50–62</td><td>62–78</td><td>78–83</td><td>83–90</td><td>90–97</td><td>97–104</td><td>104–110</td></tr>
