          <!-- Guia de medidas -->
          <div class="measurement-guide">
            <h3>How to measure:</h3>
            <p>Compare with a shirt you already have. Measure the width from armpit to armpit (chest) and the length from the collar to the hem.</p>
            <img src="https://i.imgur.com/PjGrIFi.png" alt="Guia de medidas" loading="lazy">
        </div>
      </div>
    </div>
  </div>
</div>

<style>
/* ============================================
   DRAWER & OVERLAY (Standardized)
   ============================================ */
.size-drawer-overlay {
  position: fixed;
  inset: 0;
  visibility: hidden;
  pointer-events: none;
  z-index: 2147483640;
  background: rgba(var(--color-foreground), 0.5); /* Theme standard opacity */
  transition: opacity var(--duration-default) ease, visibility var(--duration-default) ease;
  opacity: 0;
}

.size-drawer-overlay.active {
  visibility: visible;
  pointer-events: auto;
  opacity: 1;
}

.size-drawer {
  position: fixed;
  top: 0;
  right: 0;
  height: 100%;
  width: 100vw;
  display: flex;
  justify-content: flex-end;
  pointer-events: none; /* Let overlay catch backdrop clicks */
}

.size-drawer .drawer__inner {
  height: 100%;
  width: 100vw;
  max-width: 100vw;
  background: #ffffff !important;
  display: flex;
  flex-direction: column;
  transform: translateX(100%);
  transition: transform var(--duration-default) ease;
  pointer-events: auto;
}

@media screen and (min-width: 750px) {
  .size-drawer .drawer__inner {
    width: 55rem; /* Matches Cart Drawer width */
    max-width: 55rem;
  }
}

.size-drawer-overlay.active .drawer__inner {
  transform: translateX(0);
}

.size-drawer .drawer__header {
  position: relative;
  padding: 1.5rem;
  display: flex;
  justify-content: center;
  align-items: center;
  background: #ffffff !important;
  color: #000000 !important;
  z-index: 2;
  border-bottom: 1px solid rgba(0, 0, 0, 0.05);
  box-shadow: none !important;
}


.size-drawer .drawer__heading {
  margin: 0;
  font-family: var(--font-heading-family); /* Match product title font */
  font-size: 1.8rem;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.1rem;
  color: #000000 !important;
}

.size-drawer .drawer__close {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  min-width: 4.4rem;
  min-height: 4.4rem;
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  right: 1rem;
  color: #000000 !important;
  background-color: transparent;
  border: none;
  cursor: pointer;
}

.drawer__close svg {
  width: 1.8rem;
  height: 1.8rem;
}

.size-drawer .drawer__contents {
  flex-grow: 1;
  overflow-y: auto;
  padding: 2rem 1.5rem;
  background: #fff;
}

/* ============================================
   CONTENT STYLES
   ============================================ */

.size-notice {
  background-color: #fff5f5;
  border: 1px solid #ffebeb;
  border-radius: 12px;
  padding: 2rem; /* Increased padding */
  margin-bottom: 2rem;
  font-size: 1.4rem; /* Increased font size */
  line-height: 1.6;
  color: #8b4d4d;
}

.size-notice p { margin: 0 0 1rem 0; }
.size-notice p:last-child { margin-bottom: 0; }
.size-notice strong { color: #6b2d2d; font-weight: 700; }

.collapsible-container {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.collapsible-field {
  border: 1px solid rgba(0, 0, 0, 0.08);
  border-radius: 8px;
  overflow: hidden;
  background: #fff;
}

.field-header {
  width: 100%;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 1.6rem 2rem; /* Increased padding */
  background: #fff;
  border: none;
  cursor: pointer;
  font-family: var(--font-heading-family); /* Match product title font */
  font-size: 1.8rem; /* Checked against user request */
  font-weight: 800; /* Thick weight */
  color: #1a1a1a;
  text-align: left;
  transition: background 0.2s ease;
  text-transform: uppercase;
  letter-spacing: 0.05rem;
}

.field-header:hover { background: #fafafa; }

.field-header-arrow {
  transition: transform 0.3s ease;
  line-height: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #737373;
}

.field-header-arrow .svg-wrapper {
  width: 0.8rem;
  height: 0.8rem;
  display: flex;
}

.field-header.expanded .field-header-arrow { transform: rotate(180deg); }

.field-content {
  max-height: 0;
  overflow: hidden;
  opacity: 0;
  transition: max-height 0.4s cubic-bezier(0.25, 1, 0.5, 1), opacity 0.3s ease-in-out; /* Smooth animation */
}

.field-content.expanded {
  padding: 1.5rem 1.6rem 2rem;
  opacity: 1;
  max-height: none !important;
}

.table-scroll-wrapper {
  width: 100%;
  overflow-x: auto !important; /* Force scroll */
  border-radius: 12px;
  border: 1px solid rgba(0, 0, 0, 0.05);
  -webkit-overflow-scrolling: touch; /* Smooth scroll on iOS */
}

.size-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 1.2rem;
  border: none;
  /* Removed border-radius/overflow here to avoid double-clipping issues */
}

.size-table th, .size-table td {
  padding: 1rem;
  text-align: center;
  border: 1px solid rgba(0, 0, 0, 0.05);
  white-space: nowrap;
}

.size-table th { background: #f9f9f9; font-weight: 600; }
.size-table td:first-child { background: #f9f9f9; font-weight: 500; text-align: left; }

.measurement-guide {
  margin-top: 3rem;
  padding-top: 2rem;
  border-top: 1px solid rgba(0, 0, 0, 0.08);
}

.measurement-guide h3 {
  font-size: 1.6rem;
  font-weight: 700;
  margin-bottom: 1rem;
}

.measurement-guide img {
  width: 100%;
  border-radius: 8px;
  border: 1px solid rgba(0, 0, 0, 0.08);
}
</style>

<script>
(function () {
  const STATE = { initialized: false };

  function boot() {
    if (STATE.initialized) return;
    STATE.initialized = true;

    /* == Selectors must match the new HTML structure == */
    const openBtn = document.getElementById('abrirTabela-{{ section.id }}');
    const overlayId = 'sizePanelOverlay-{{ section.id }}';
    const overlay = document.getElementById(overlayId);
    const closeBtn = overlay?.querySelector('.drawer__close');
    const inner    = overlay?.querySelector('.drawer__inner');

    // Move overlay to body to ensure correct stacking
    if (overlay && overlay.parentNode !== document.body) {
      // Check if an overlay with this ID already exists in body and remove it (cleanup old renders)
      const existingOverlay = document.body.querySelector(`#${overlayId}`);
      if (existingOverlay && existingOverlay !== overlay) {
          existingOverlay.remove();
      }
      document.body.appendChild(overlay);
    }

    if (!openBtn || !overlay) return;

    function openPanel() {
      overlay.classList.add('active'); // CSS handles display & opacity
      document.body.style.overflow = 'hidden';
      // Trigger update/reflow if needed, though CSS transitions handle it
    }

    function closePanel() {
      overlay.classList.remove('active');
      document.body.style.overflow = '';
      // Wait for transition if needed, CSS transition is on opacity
    }

    // --- Event Listeners ---
    openBtn.addEventListener('click', (e) => {
      e.preventDefault();
      openPanel();
    });

    if (closeBtn) {
      closeBtn.addEventListener('click', (e) => {
        e.preventDefault();
        closePanel();
      });
    }

    // Close on click outside (overlay click)
    overlay.addEventListener('click', (e) => {
      // If clicking exactly on the overlay (backdrop), close.
      // The inner drawer stops propagation implicitly or checks target.
      if (e.target === overlay) {
        closePanel();
      }
    });

    // Close on ESC
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && overlay.classList.contains('active')) {
        closePanel();
      }
    });

    // --- Collapsibles Logic (Restored) ---
    function toggleField(fieldId) {
      const headerBtn = overlay.querySelector(`[data-target="${CSS.escape(fieldId)}"]`);
      const content   = overlay.querySelector('#' + CSS.escape(fieldId));
      if (!headerBtn || !content) return;

      const isExpanded = content.classList.contains('expanded');

      if (isExpanded) {
        content.classList.remove('expanded');
        headerBtn.classList.remove('expanded');
        content.style.maxHeight = '0';
      } else {
        content.classList.add('expanded');
        headerBtn.classList.add('expanded');
        content.style.maxHeight = content.scrollHeight + 'px';
      }
    }

    overlay.querySelectorAll('.field-header').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        const targetId = btn.getAttribute('data-target');
        if (targetId) toggleField(targetId);
      });
    });

    // Global Exposure
    window.openSizePanel  = openPanel;
    window.closeSizePanel = closePanel;
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', boot);
  } else {
    boot();
  }
})();
</script>


