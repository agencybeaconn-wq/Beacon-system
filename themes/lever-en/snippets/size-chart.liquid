

<!-- Painel lateral da Tabela de Medidas -->
<div id="sizePanelOverlay-{{ section.id }}" class="size-drawer-overlay">
  <div class="size-drawer" id="SizeDrawer" role="dialog" aria-modal="true" aria-label="Tabela de Medidas" tabindex="-1">
    <div class="drawer__inner">
      <div class="drawer__header">
        <h2 class="drawer__heading">SIZE CHART</h2>
        <button class="drawer__close" aria-label="Close">
          <span class="svg-wrapper">
            {{- 'icon-close.svg' | inline_asset_content -}}
          </span>
        </button>
      </div>

      <div class="drawer__contents size-panel-content">
        <!-- AVISO ESPECÍFICO -->
          <div class="size-notice">
            <p><strong>Fan and Women's Version:</strong> we recommend choosing <strong>1 size larger</strong> than usual.</p>
            <p><strong>Player Version (Authentic):</strong> is extremely tight. We recommend <strong>1 or even 2 sizes larger</strong> than what you usually wear.</p>
          </div>

          <!-- COLAPSÁVEIS -->
          <div class="collapsible-container">

            <!-- Masculina Torcedor -->
