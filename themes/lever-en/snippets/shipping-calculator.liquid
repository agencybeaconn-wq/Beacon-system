{% comment %}
  Renders a shipping calculator block for the product page.
  Accepts:
  - block: {Object} block object with settings.
  - section_id: {String} id of section to which this snippet belongs.
{% endcomment %}

<div class="unique-shipping-section animate--slide-in" {{ block.shopify_attributes }}>
   <div class="guarantee-header no-cursor">
      <span class="guarantee-icon">
         <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg>
      </span>
      <div class="guarantee-text">
         <span class="guarantee-title">{{ block.settings.title | default: 'Calculate shipping and delivery time' }}</span>
         <span class="guarantee-subtitle">{{ block.settings.subtitle | default: 'Simulate with your ZIP code' }}</span>
      </div>
   </div>
   <div class="guarantee-content open">
       <!-- State 1: Input -->
       <div id="shipping-initial-state-{{ section_id }}">
          <div class="shipping-input-group">
             <input type="text" id="cep-input-{{ section_id }}" class="cep-field" placeholder="Enter your ZIP code" maxlength="9">
             <button type="button" id="calc-shipping-btn-{{ section_id }}" class="calc-btn">
               <span class="btn-text">Calculate</span>
               <span class="loading-spinner hidden">
                 <svg aria-hidden="true" focusable="false" role="presentation" class="spinner" viewBox="0 0 66 66" xmlns="http://www.w3.org/2000/svg">
                   <circle class="path" fill="none" stroke-width="6" cx="33" cy="33" r="30"></circle>
                 </svg>
               </span>
             </button>
          </div>
          <a href="https://buscacepinter.correios.com.br/app/localidade_logradouro/index.php" target="_blank" class="find-cep-link" style="font-size: 1.2rem; text-decoration: underline; color: #666; margin-top: 0.8rem; display: inline-block;">I don't know my ZIP code</a>
       </div>

       <!-- State 2: Results -->
       <div id="shipping-results-state-{{ section_id }}" class="shipping-results" style="display: none;">
          <!-- Header with Recalculate -->
          <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
             <span style="font-size: 1.3rem; font-weight: 500;">Options for <span id="cep-display-{{ section_id }}" style="font-weight: 700;"></span>:</span>
             <button type="button" onclick="resetShipping('{{ section_id }}')" style="background: none; border: none; text-decoration: underline; cursor: pointer; color: #666; font-size: 1.2rem; font-family: var(--font-body-family);">New Simulation</button>
          </div>

          <div class="shipping-options-display">
             {%- for i in (1..4) -%}
                {%- assign title_key = 'option_' | append: i | append: '_title' -%}
                {%- assign option_title = block.settings[title_key] -%}
                
                {%- if option_title != blank -%}
                  <div class="shipping-option-static">
                     <div class="option-info">
                        <span class="option-name">{{ option_title }}</span>
                     </div>
                  </div>
                {%- endif -%}
             {%- endfor -%}
          </div>
       </div>
   </div>
</div>

<style>
  .shipping-options-display {
    border: 1px solid #e5e5e5;
    border-radius: 1.2rem;
    overflow: hidden;
    margin-top: 1rem;
    box-shadow: 0 2px 8px rgba(0,0,0,0.05);
  }
  .shipping-option-static {
    padding: 1.6rem;
    display: flex;
    align-items: center;
    background: #fff;
    transition: background 0.2s ease;
  }
  .shipping-option-static:not(:last-child) {
    border-bottom: 1px solid #f0f0f0;
  }
  .shipping-option-static .option-name {
    font-size: 1.3rem;
    font-weight: 500;
    color: #1a1a1a;
  }
</style>

<script>
  if (!window.shippingInitialized) {
    window.shippingInitialized = true;
    
    // Global function for reset
    window.resetShipping = function(sectionId) {
        const results = document.getElementById(`shipping-results-state-${sectionId}`);
        const initial = document.getElementById(`shipping-initial-state-${sectionId}`);
        const input = document.getElementById(`cep-input-${sectionId}`);
        
        if (results) results.style.display = 'none';
        if (initial) initial.style.display = 'block';
        if (input) {
          input.value = '';
          input.focus();
        }
    };
  }

  document.addEventListener('DOMContentLoaded', function() {
      const sectionId = "{{ section_id }}";
      const cepInput = document.getElementById(`cep-input-${sectionId}`);
      const calcBtn = document.getElementById(`calc-shipping-btn-${sectionId}`);
      const initialState = document.getElementById(`shipping-initial-state-${sectionId}`);
      const resultsState = document.getElementById(`shipping-results-state-${sectionId}`);
      const cepDisplay = document.getElementById(`cep-display-${sectionId}`);
      
      if (!calcBtn) return;

      const btnText = calcBtn.querySelector('.btn-text');
      const btnSpinner = calcBtn.querySelector('.loading-spinner');

      // Mask CEP
      cepInput.addEventListener('input', function(e) {
        let value = e.target.value.replace(/\D/g, "");
        if (value.length > 5) {
          value = value.replace(/^(\d{5})(\d)/, "$1-$2");
        }
        e.target.value = value;
      });

      // Calculate Action
      calcBtn.addEventListener('click', function() {
         const cleanValue = cepInput.value.replace(/\D/g, "");
         if(cleanValue.length === 8) {
            // Show Spinner
            btnText.classList.add('hidden');
            btnSpinner.classList.remove('hidden');
            calcBtn.disabled = true;

            // Simulate loading
            setTimeout(() => {
               // Reset Button
               calcBtn.disabled = false;
               btnText.classList.remove('hidden');
               btnSpinner.classList.add('hidden');

               // Toggle Layout
               cepDisplay.innerText = cepInput.value;
               initialState.style.display = 'none';
               resultsState.style.display = 'block';
            }, 800);
         } else {
            alert('Please enter a valid ZIP code.');
         }
      });
  });
</script>
