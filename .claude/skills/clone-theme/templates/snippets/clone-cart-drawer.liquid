{%- comment -%}
  clone-theme — Cart Drawer lateral estilo Lucky Fours
  - Lateral direita, slide-in
  - Lista de items com qty pill, lixeira, preço cortado, Save $X verde, badge BOGO
  - Shipping Protection toggle
  - Discount preview (BOGO)
  - Checkout button com total
  - Métodos de pagamento (express checkout)

  Settings (config/settings_schema.json):
    - clone_shipping_protection_variant_id: variant ID do produto Shipping Protection
    - clone_bogo_discount_label: texto do badge BOGO
{%- endcomment -%}

<aside class="clone-cart-drawer" id="CloneCartDrawer" aria-hidden="true" role="dialog" aria-label="Carrinho">
  <div class="clone-cart-drawer__overlay" data-cart-close></div>
  <div class="clone-cart-drawer__panel">
    <header class="clone-cart-drawer__head">
      <h2 class="clone-cart-drawer__title">Cart • <span data-cart-count>0</span></h2>
      <button type="button" class="clone-cart-drawer__close" aria-label="Fechar carrinho" data-cart-close>
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6L6 18M6 6l12 12"/></svg>
      </button>
    </header>

    <div class="clone-cart-drawer__body">
      <ul class="clone-cart-drawer__items" data-cart-items></ul>

      <div class="clone-cart-drawer__empty" data-cart-empty hidden>
        <p>Seu carrinho está vazio.</p>
      </div>

      {%- if settings.clone_upsell_enabled -%}
      <section class="clone-cart-upsell" data-cart-upsell hidden>
        <div class="clone-cart-upsell__head">
          <h3 class="clone-cart-upsell__title">{{ settings.clone_upsell_title | default: 'Mix & Match' }}</h3>
          <p class="clone-cart-upsell__subtitle">{{ settings.clone_upsell_subtitle | default: 'Buy 1 Get 1 Free' }}</p>
        </div>
        <div class="clone-cart-upsell__carousel">
          <button type="button" class="clone-cart-upsell__nav clone-cart-upsell__nav--prev" data-upsell-prev aria-label="Anterior">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
          </button>
          <div class="clone-cart-upsell__track" data-upsell-track></div>
          <button type="button" class="clone-cart-upsell__nav clone-cart-upsell__nav--next" data-upsell-next aria-label="Próximo">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
          </button>
        </div>
      </section>
      {%- endif -%}
    </div>

    <footer class="clone-cart-drawer__foot">
      {% if settings.clone_shipping_protection_variant_id != blank %}
        <div class="clone-cart-drawer__shipping-protection">
          <div class="clone-cart-drawer__sp-icon">
            <svg viewBox="0 0 32 32" width="36" height="36" xmlns="http://www.w3.org/2000/svg">
              <defs>
                <linearGradient id="cloneShipShield" x1="0" y1="0" x2="1" y2="1">
                  <stop offset="0" stop-color="#5fc6ec"/>
                  <stop offset="1" stop-color="#2a8fc7"/>
                </linearGradient>
              </defs>
              <path fill="url(#cloneShipShield)" d="M16 2L4 6v8c0 7 5 12 12 14 7-2 12-7 12-14V6L16 2z"/>
              <path fill="#fff" d="M14.6 19.7l-4-4 1.7-1.7 2.3 2.3 5.4-5.4 1.7 1.7-7.1 7.1z"/>
              <circle cx="22" cy="22" r="4" fill="#fff"/>
              <path fill="#2a8fc7" d="M22 19.6c-1.3 0-2.4 1.1-2.4 2.4s1.1 2.4 2.4 2.4 2.4-1.1 2.4-2.4-1.1-2.4-2.4-2.4zm.7 3.6h-1.1v-1.4h.5v.9h.6v.5z"/>
            </svg>
          </div>
          <div class="clone-cart-drawer__sp-text">
            <strong>Shipping Protection</strong>
            <span>Protect your order from damage, loss, or theft during shipping.</span>
          </div>
          <div class="clone-cart-drawer__sp-right">
            <span class="clone-cart-drawer__sp-price" data-shipping-price>$4.99</span>
            <label class="clone-cart-drawer__toggle">
              <input type="checkbox" data-shipping-toggle data-variant-id="{{ settings.clone_shipping_protection_variant_id }}">
              <span class="clone-cart-drawer__toggle-track"><span class="clone-cart-drawer__toggle-thumb"></span></span>
            </label>
          </div>
        </div>
      {% endif %}

      {%- comment -%} bloco Discounts removido — cálculo BOGO continua aplicado ao total {%- endcomment -%}

      <a href="/checkout" class="clone-cart-drawer__checkout" data-cart-checkout>
        Checkout • <span data-cart-total>$0.00</span>
      </a>

      <div class="clone-cart-drawer__payments" aria-label="Métodos de pagamento">
        {%- comment -%} SVG inline pra não depender de CDN externo {%- endcomment -%}
        <span class="clone-cart-drawer__pay" aria-label="Apple Pay">
          <svg viewBox="0 0 38 24" xmlns="http://www.w3.org/2000/svg"><rect width="38" height="24" rx="3" fill="#000"/><path fill="#fff" d="M10.66 9.16c-.34.4-.88.71-1.42.66-.07-.54.19-1.1.5-1.45.34-.4.93-.7 1.41-.72.06.55-.16 1.1-.49 1.51zm.48.77c-.78-.04-1.45.44-1.82.44-.37 0-.94-.42-1.56-.41-.8.01-1.54.46-1.95 1.19-.84 1.45-.22 3.59.6 4.77.4.59.88 1.23 1.51 1.21.6-.02.83-.39 1.55-.39s.94.39 1.56.38c.65-.01 1.06-.59 1.45-1.18.46-.67.64-1.32.65-1.36-.01-.01-1.24-.48-1.25-1.88-.01-1.17.96-1.73 1-1.76-.55-.81-1.4-.9-1.69-.92zm4.5-1.81v8.21h1.27v-2.81h1.76c1.6 0 2.73-1.11 2.73-2.71 0-1.6-1.1-2.69-2.69-2.69h-3.07zm1.27 1.06h1.47c1.1 0 1.74.59 1.74 1.64s-.63 1.64-1.74 1.64h-1.47V9.18zm6.74 7.21c.8 0 1.54-.4 1.88-1.05h.03v.99h1.18v-4.07c0-1.19-.95-1.96-2.41-1.96-1.36 0-2.36.78-2.4 1.85h1.15c.09-.51.56-.85 1.21-.85.79 0 1.24.37 1.24 1.05v.46l-1.61.1c-1.5.09-2.31.7-2.31 1.78 0 1.08.84 1.8 2.05 1.8zm.34-1c-.69 0-1.13-.33-1.13-.83 0-.52.42-.85 1.23-.89l1.44-.09v.47c0 .78-.66 1.34-1.54 1.34zM30 18.5c1.25 0 1.84-.48 2.36-1.93l2.25-6.3h-1.3l-1.5 4.87h-.03l-1.5-4.87h-1.32l2.17 6.01-.11.36c-.2.63-.51.87-1.09.87-.1 0-.3-.01-.37-.03v.99c.08.02.4.04.48.04z"/></svg>
        </span>
        <span class="clone-cart-drawer__pay" aria-label="Google Pay">
          <svg viewBox="0 0 38 24" xmlns="http://www.w3.org/2000/svg"><rect width="38" height="24" rx="3" fill="#fff" stroke="#d8d8d8"/><path fill="#3c4043" d="M18.05 12.21v2.61h-.83V8.4h2.2c.55 0 1.03.19 1.42.55.4.37.59.82.59 1.35 0 .54-.2.99-.59 1.35-.38.36-.86.54-1.42.54h-1.37v.02zm0-3.01v2.21h1.39c.33 0 .61-.11.83-.33.22-.22.34-.49.34-.78 0-.28-.11-.55-.34-.77a1.15 1.15 0 00-.83-.33h-1.39zm5.4 1.07c.61 0 1.1.16 1.45.49.36.33.54.78.54 1.35v2.71h-.79v-.61h-.04c-.34.51-.81.77-1.39.77-.49 0-.91-.15-1.24-.44-.34-.29-.51-.66-.51-1.1 0-.46.18-.83.53-1.11.35-.28.83-.42 1.42-.42.51 0 .92.09 1.24.28v-.19c0-.29-.12-.53-.34-.74-.23-.2-.5-.3-.81-.3-.47 0-.84.2-1.11.6l-.74-.46c.41-.55 1-.83 1.79-.83zm-1.08 3.21c0 .22.09.4.28.55.18.15.41.22.66.22.35 0 .68-.13.96-.39.28-.26.42-.57.42-.93-.27-.21-.64-.32-1.11-.32-.34 0-.63.08-.86.25-.24.16-.36.37-.36.62zm8.43-3.07l-2.76 6.36h-.86l1.03-2.22-1.82-4.14h.91l1.32 3.18.01.01 1.28-3.19h.89z"/><path fill="#4285f4" d="M14.91 11.66c0-.26-.02-.51-.06-.76H11.4v1.41h2c-.08.45-.33.84-.7 1.1v.91h1.13c.66-.61 1.04-1.51 1.04-2.66z"/><path fill="#34a853" d="M11.4 15.14c.95 0 1.74-.31 2.32-.85l-1.13-.88c-.31.21-.72.34-1.19.34-.91 0-1.69-.62-1.96-1.45h-1.16v.91a3.5 3.5 0 003.12 1.93z"/><path fill="#fabb05" d="M9.44 12.3a2.18 2.18 0 010-1.4v-.91h-1.17a3.45 3.45 0 000 3.22l1.17-.91z"/><path fill="#e94235" d="M11.4 9.45c.51 0 .97.18 1.34.52l1-1c-.6-.56-1.39-.9-2.34-.9a3.5 3.5 0 00-3.13 1.94l1.17.91c.27-.83 1.05-1.47 1.96-1.47z"/></svg>
        </span>
        <span class="clone-cart-drawer__pay" aria-label="PayPal">
          <svg viewBox="0 0 38 24" xmlns="http://www.w3.org/2000/svg"><rect width="38" height="24" rx="3" fill="#fff" stroke="#d8d8d8"/><path fill="#003087" d="M15.6 8.6h-3.05a.43.43 0 00-.42.36L10.9 16.7c-.02.13.08.25.21.25h1.46a.43.43 0 00.42-.36l.33-2.13a.43.43 0 01.42-.36h.97c2.01 0 3.18-.97 3.48-2.9.14-.85.01-1.51-.39-1.97-.43-.5-1.19-.77-2.2-.77zm.35 2.86c-.16 1.06-.97 1.06-1.76 1.06h-.45l.32-1.99a.26.26 0 01.26-.22h.2c.54 0 1.05 0 1.31.31.16.18.21.46.12.84z"/><path fill="#009cde" d="M23.04 11.42h-1.46a.26.26 0 00-.26.22l-.07.41-.1-.15c-.32-.46-1.02-.62-1.72-.62-1.61 0-2.99 1.22-3.26 2.93-.14.86.06 1.67.55 2.24.45.52 1.09.74 1.86.74 1.3 0 2.02-.83 2.02-.83l-.07.41a.26.26 0 00.26.3h1.31a.43.43 0 00.42-.36l.79-4.99a.26.26 0 00-.26-.3zm-2.04 2.83c-.14.84-.81 1.4-1.66 1.4-.43 0-.78-.14-1-.4-.22-.26-.3-.62-.23-1.04.13-.83.81-1.41 1.65-1.41.42 0 .77.14.99.4.22.26.31.63.25 1.05z"/><path fill="#003087" d="M30.86 11.42h-1.47a.43.43 0 00-.35.18l-2.03 2.99-.86-2.87a.43.43 0 00-.41-.3h-1.45a.26.26 0 00-.25.34l1.62 4.74-1.52 2.14a.26.26 0 00.21.41h1.47c.14 0 .27-.07.35-.18l4.9-7.08a.26.26 0 00-.21-.4z"/></svg>
        </span>
        <span class="clone-cart-drawer__pay" aria-label="American Express">
          <svg viewBox="0 0 38 24" xmlns="http://www.w3.org/2000/svg"><rect width="38" height="24" rx="3" fill="#006fcf"/><path fill="#fff" d="M11.7 9.8h2.2L15 12l1.1-2.2h6.8v.7l.5-.7h2.1l.5.7v-.7h3.1l.6.7v-.7h2v4.6h-2L29 13.7v.7h-3.1l-.4-.5h-1l-.4.5h-2c-.5 0-.8-.2-1-.4-.2.2-.5.4-1.1.4h-2.6l-.4-.5h-1l-.4.5h-2.1v-4.6zm.6.5v3.6h1.5l.5-1.1H16l.5 1.1h1.5v-2.8l1.3 2.8h.7l1.3-2.8v2.8h.9v-3.6h-1.4l-1 2.4-1-2.4h-1.5v3.4l-1.5-3.4h-1.3l-1.5 3.6h.9l.3-.7h2l.3.7h1l-.3-.7-1.4-2.9zm12.3 0v3.6h2.9v-.7H25v-.8h2.4v-.6H25v-.8h2.6v-.7h-3zm3.5 0l1.3 1.8-1.4 1.8h1l.9-1.2.9 1.2h1l-1.4-1.8 1.3-1.8h-.9l-.9 1.1-.9-1.1h-.9zm-12.7 1.4l.4 1h-.8l.4-1zm5.4-.7v.8h-1.4v-.8h1.4zm0 1.4v.8h-1.4v-.8h1.4z"/></svg>
        </span>
        <span class="clone-cart-drawer__pay" aria-label="Visa">
          <svg viewBox="0 0 38 24" xmlns="http://www.w3.org/2000/svg"><rect width="38" height="24" rx="3" fill="#1a1f71"/><path fill="#fff" d="M17 15.5h-2L16.5 9h2L17 15.5zm-3.5-3l-1.9 3.1L11.4 14l-.7-3.4s-.1-.7-1-.7H6.7L6.6 9h3.2c.4 0 .9.3 1 .9l.9 4.7L13.4 9h2l-3.7 6.5h-2L11 9h-1.5l1.7 6.5h-2L13.5 12.5zm12.3 3h1.7L25.5 9H24c-.7 0-.9.5-.9.5l-2.5 6h2l.4-1.1h2.5l.3 1.1zm-2-2.6l1-2.7.6 2.7H24z"/></svg>
        </span>
        <span class="clone-cart-drawer__pay" aria-label="Mastercard">
          <svg viewBox="0 0 38 24" xmlns="http://www.w3.org/2000/svg"><rect width="38" height="24" rx="3" fill="#fff" stroke="#d8d8d8"/><circle cx="15.5" cy="12" r="6" fill="#eb001b"/><circle cx="22.5" cy="12" r="6" fill="#f79e1b"/><path fill="#ff5f00" d="M19 7.6a6 6 0 010 8.8 6 6 0 010-8.8z"/></svg>
        </span>
        <span class="clone-cart-drawer__pay" aria-label="Maestro">
          <svg viewBox="0 0 38 24" xmlns="http://www.w3.org/2000/svg"><rect width="38" height="24" rx="3" fill="#fff" stroke="#d8d8d8"/><circle cx="15.5" cy="12" r="6" fill="#0099df"/><circle cx="22.5" cy="12" r="6" fill="#ed0006"/><path fill="#6c6bbd" d="M19 7.6a6 6 0 010 8.8 6 6 0 010-8.8z"/></svg>
        </span>
        <span class="clone-cart-drawer__pay" aria-label="OPay">
          <svg viewBox="0 0 38 24" xmlns="http://www.w3.org/2000/svg"><rect width="38" height="24" rx="3" fill="#5d2ee0"/><text x="19" y="16" font-family="Arial, sans-serif" font-size="9" font-weight="700" fill="#fff" text-anchor="middle" letter-spacing="0.5">OPay</text></svg>
        </span>
      </div>
    </footer>
  </div>
</aside>

{%- comment -%} Template de card upsell {%- endcomment -%}
<template id="CloneUpsellCardTemplate">
  <article class="clone-upsell-card" data-upsell-card data-product-id="">
    <a class="clone-upsell-card__media" data-upsell-link href="">
      <img data-upsell-image src="" alt="" loading="lazy">
    </a>
    <div class="clone-upsell-card__body">
      <a class="clone-upsell-card__title" data-upsell-link href="">
        <strong data-upsell-title></strong>
      </a>
      <div class="clone-upsell-card__prices">
        <span class="clone-upsell-card__compare" data-upsell-compare hidden></span>
        <strong class="clone-upsell-card__price" data-upsell-price></strong>
      </div>
      <div class="clone-upsell-card__actions">
        <select class="clone-upsell-card__select" data-upsell-variant aria-label="Variante"></select>
        <button type="button" class="clone-upsell-card__add" data-upsell-add>Add to cart</button>
      </div>
    </div>
  </article>
</template>

{%- comment -%} Template de item: usado pelo JS pra clonar e popular {%- endcomment -%}
<template id="CloneCartItemTemplate">
  <li class="clone-cart-item" data-cart-line data-line-key="" data-variant-id="">
    <a class="clone-cart-item__image" data-line-link href="">
      <img data-line-image src="" alt="" loading="lazy">
    </a>
    <div class="clone-cart-item__info">
      <div class="clone-cart-item__head">
        <a class="clone-cart-item__title" data-line-link href="">
          <strong data-line-title></strong>
        </a>
        <button type="button" class="clone-cart-item__remove" data-cart-remove aria-label="Remover">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-2 14a2 2 0 0 1-2 2H9a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2v2"/></svg>
        </button>
      </div>
      <div class="clone-cart-item__variant" data-line-variant></div>
      <div class="clone-cart-item__qty">
        <button type="button" class="clone-cart-item__qty-btn" data-cart-qty-dec aria-label="Diminuir">−</button>
        <span class="clone-cart-item__qty-value" data-line-qty>1</span>
        <button type="button" class="clone-cart-item__qty-btn" data-cart-qty-inc aria-label="Aumentar">+</button>
      </div>
      <div class="clone-cart-item__price-block">
        <div class="clone-cart-item__prices">
          <span class="clone-cart-item__compare" data-line-compare hidden></span>
          <strong class="clone-cart-item__price" data-line-price></strong>
        </div>
        <div class="clone-cart-item__save" data-line-save hidden></div>
        {%- comment -%} badge BOGO removido conforme pedido {%- endcomment -%}
      </div>
    </div>
  </li>
</template>
