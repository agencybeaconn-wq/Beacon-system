{%- comment -%}
  Script de patches adaptado para temas Dawn e Kalles da Shopify
  Detecta patches baseado no título do produto e permite adicionar ao carrinho
  Compatível com Web Components do Dawn e sistema T4S do Kalles
{%- endcomment -%}

{%- liquid
  assign product_form_id = 'product-form-' | append: pr_se_id
-%}

<script>
  (function() {
    // Duplicate guard
    if (window.patchScriptInitialized) {
      console.log('DEBUG: patch-script already initialized, skipping duplicate.');
      return;
    }
    window.patchScriptInitialized = true;
    
    // Store selected patch products
    const selectedPatches = new Map();
    // Store cart item keys for patches (to remove them later)
    const patchCartKeys = new Map();
    // Store custom patch positions
    const customPatchPositions = new Map();
    // Flag to prevent infinite loops when syncing patch properties
    let isSyncingPatchProperties = false;
    // Flag to prevent infinite loops when deselecting patches programmatically
    let isDeselectingPatches = false;
    const productCollections = {{ product.collections | map: 'handle' | json }};
    const productTitle = {{ product.title | json }} || '';
    const productFormId = '{{ product_form_id }}';
    
    // Flags for patch loading
    let patchesLoaded = false;
    let isLoadingPatches = false;
    let patchSectionExpanded = false;
    
    // Toggle functionality with smooth CSS transitions
    function initPatchToggle() {
      const toggle = document.querySelector('.patch-section-toggle');
      if (!toggle) return;
      
      console.log('DEBUG: Patch toggle initialized');
      
      toggle.addEventListener('click', function() {
        console.log('DEBUG: Patch toggle clicked');
        const selector = document.getElementById('patch-products-selector');
        
        patchSectionExpanded = !patchSectionExpanded;
        
        if (patchSectionExpanded) {
          // Open - let CSS handle the smooth transition
          if (selector) {
            selector.classList.add('is-open');
          }
          toggle.setAttribute('aria-expanded', 'true');
          loadPatchProducts();
        } else {
          // Close - let CSS handle the smooth transition
          if (selector) {
            selector.classList.remove('is-open');
          }
          toggle.setAttribute('aria-expanded', 'false');
        }
      });
    }

    // Initialize toggle when DOM is ready
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', function() {
        initPatchToggle();
        initAddToCartButtonListeners();
        // AUTO-LOAD PATCHES: Trigger loading immediately so the drawer is ready
        setTimeout(loadPatchProducts, 500); 
      });
    } else {
      initPatchToggle();
      initAddToCartButtonListeners();
      // AUTO-LOAD PATCHES: Trigger loading immediately
      setTimeout(loadPatchProducts, 500);
    }

    function initAddToCartButtonListeners() {
      console.log('DEBUG: Initializing add to cart button listeners');
      
      // Flag to track if we're currently adding patches
      let isAddingPatches = false;
      
      // Function to handle button click - OPTIMISTIC UI: trigger theme immediately, add patches in background
      async function handleAddToCartClick(e) {
        const hasPatches = selectedPatches.size > 0 || 
                          document.querySelectorAll('.patch-checkbox:checked').length > 0;
        
        if (!hasPatches || isAddingPatches) {
          // No patches or already processing - let theme handle normally
          return true;
        }
        
        console.log('DEBUG: Patches selected - using optimistic UI');
        
        // Prevent the default action temporarily
        e.preventDefault();
        e.stopPropagation();
        e.stopImmediatePropagation();
        
        isAddingPatches = true;
        
        const button = e.target.closest('button') || e.target;
        const form = document.getElementById(productFormId) || 
                    button.closest('form') || 
                    document.querySelector('form[action*="/cart/add"]');
        
        if (!form) {
          console.error('Form not found');
          isAddingPatches = false;
          return false;
        }
        
        const formData = new FormData(form);
        const variantId = formData.get('id');
        const quantity = parseInt(formData.get('quantity') || '1', 10);
        
        if (!variantId) {
          alert('Please select a variant');
          isAddingPatches = false;
          return false;
        }
        
        // Generate unique ID for this order (prevents Shopify from stacking items)
        const uniqueItemId = Date.now().toString() + '-' + Math.random().toString(36).substr(2, 9);
        const cartUrl = window.themeVariables?.routes?.cartUrl || '/cart';
        
        // Get patch titles for main product properties
        const patchTitles = [];
        const patchesToAdd = [];
        
        selectedPatches.forEach((patch, patchKey) => {
          const isValid = validateSleevePatchSelection(patch, patchKey, false);
          if (isValid) {
            patchTitles.push(patch.title);
            patchesToAdd.push({
              id: parseInt(patch.id, 10),
              quantity: quantity,
              properties: {
                '_is_patch': 'true',
                '_main_product_variant': variantId.toString(),
                '_patch_product': patch.handle,
                '_patch_title': patch.title,
                '_order_id': uniqueItemId // Unique ID to prevent stacking
              }
            });
          }
        });
        
        // Build main product with unique properties (prevents stacking)
        const mainProperties = extractPropertiesFromForm(formData);
        mainProperties['_order_id'] = uniqueItemId; // Unique ID prevents Shopify from stacking
        if (patchTitles.length > 0) {
          mainProperties['Patches'] = patchTitles.join(', ');
        }
        
        const mainProduct = {
          id: parseInt(variantId, 10),
          quantity: quantity,
          properties: mainProperties
        };
        
        // Add selling plan if present
        const sellingPlanId = formData.get('selling_plan');
        if (sellingPlanId) {
          mainProduct.selling_plan = sellingPlanId;
        }
        
        // Clear patch selections IMMEDIATELY (optimistic)
        selectedPatches.clear();
        patchCartKeys.clear();
        document.querySelectorAll('.patch-product-item').forEach(item => item.classList.remove('selected'));
        document.querySelectorAll('.patch-checkbox').forEach(checkbox => { checkbox.checked = false; });
        
        // Add loading state to button (same as theme uses)
        button.classList.add('loading', 'is-loading', 't4s-btn-loading');
        button.setAttribute('aria-busy', 'true');
        button.setAttribute('aria-disabled', 'true');
        button.disabled = true;
        
        // Show spinner in button if theme supports it
        const loadingSpinner = button.querySelector('.t4s-loading__spinner, .t4s-cart-spinner');
        if (loadingSpinner) loadingSpinner.removeAttribute('hidden');
        
        // Add loading spinner if not present
        if (!button.querySelector('.t4s-loading__spinner')) {
          const spinner = document.createElement('span');
          spinner.className = 't4s-loading__spinner';
          spinner.innerHTML = '<svg width="16" height="16" class="t4s-svg-spinner" viewBox="0 0 66 66" xmlns="http://www.w3.org/2000/svg"><circle class="t4s-path" fill="none" stroke-width="6" cx="33" cy="33" r="30"></circle></svg>';
          button.appendChild(spinner);
        }
        
        // Add ALL items (patches FIRST, then product) via API with unique IDs
        // IMPORTANT: Patches must always be added before the main product to maintain order
        const allItems = [...patchesToAdd, mainProduct];
        
        console.log('DEBUG: Adding items with unique ID:', uniqueItemId);
        
        fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ items: allItems })
        })
        .then(response => {
          if (!response.ok) {
            throw new Error('Failed to add items to cart');
          }
          console.log('DEBUG: Items added to cart');
          
          // Fetch updated cart with sections for cart drawer (Dawn + Kalles)
          return fetch(`${cartUrl}?sections=cart-drawer,cart-icon-bubble,mini-cart`);
        })
        .then(r => r.json())
        .then(sectionsData => {
          console.log('DEBUG: Sections fetched');
          
          // Try Dawn cart-drawer first
          const dawnCartDrawer = document.querySelector('cart-drawer');
          if (dawnCartDrawer && sectionsData['cart-drawer']) {
            console.log('DEBUG: Updating Dawn cart-drawer');
            const tempDiv = document.createElement('div');
            tempDiv.innerHTML = sectionsData['cart-drawer'];
            
            // Find the CartDrawer inner content
            const newCartDrawer = tempDiv.querySelector('#CartDrawer');
            const existingCartDrawer = document.getElementById('CartDrawer');
            
            if (newCartDrawer && existingCartDrawer) {
              existingCartDrawer.innerHTML = newCartDrawer.innerHTML;
            }
            
            // Remove is-empty class if cart has items
            dawnCartDrawer.classList.remove('is-empty');
          }
          
          // Update Kalles mini cart if present
          const kallesMiniCart = document.getElementById('t4s-mini_cart');
          if (kallesMiniCart && sectionsData['mini-cart']) {
            const tempDiv = document.createElement('div');
            tempDiv.innerHTML = sectionsData['mini-cart'];
            
            // Find the inner content to replace
            const newContent = tempDiv.querySelector('.t4s-drawer__wrap, .t4s-mini_cart__items, [data-cart-items]');
            const existingContent = kallesMiniCart.querySelector('.t4s-drawer__wrap, .t4s-mini_cart__items, [data-cart-items]');
            
            if (newContent && existingContent) {
              existingContent.innerHTML = newContent.innerHTML;
            } else if (sectionsData['mini-cart']) {
              const wrapper = kallesMiniCart.querySelector('.t4s-drawer__main') || kallesMiniCart;
              wrapper.innerHTML = sectionsData['mini-cart'];
            }
            
            // Update cart count attribute
            const cartCountMatch = sectionsData['mini-cart'].match(/data-ccount="(\d+)"/);
            if (cartCountMatch) {
              kallesMiniCart.setAttribute('data-ccount', cartCountMatch[1]);
            }
          }
          
          // Update Dawn cart icon bubble if present
          if (sectionsData['cart-icon-bubble']) {
            const cartIconBubble = document.getElementById('cart-icon-bubble');
            if (cartIconBubble) {
              const tempDiv = document.createElement('div');
              tempDiv.innerHTML = sectionsData['cart-icon-bubble'];
              const newBubble = tempDiv.querySelector('#cart-icon-bubble');
              if (newBubble) {
                cartIconBubble.innerHTML = newBubble.innerHTML;
              }
            }
          }
          
          // Update cart count in header
          return fetch(`${cartUrl}.js`);
        })
        .then(r => r.json())
        .then(cartData => {
          // Update cart count elements (Dawn + Kalles selectors)
          const cartCountElements = document.querySelectorAll('[data-cart-count], .t4s-cart-count, .cart-count, [data-header-cart-count], .cart-count-bubble span');
          cartCountElements.forEach(el => {
            if (cartData.item_count !== undefined) {
              el.textContent = cartData.item_count;
              el.style.display = cartData.item_count > 0 ? '' : 'none';
            }
          });
          
          // Trigger cart update events for both themes
          const events = ['cart:updated', 'cart:refresh', 't4s:cart:updated', 'shopify:cart:updated'];
          events.forEach(eventName => {
            document.documentElement.dispatchEvent(new CustomEvent(eventName, {
              bubbles: true,
              detail: { cart: cartData }
            }));
          });
          
          // jQuery events for Kalles
          if (typeof jQuery !== 'undefined') {
            jQuery(document).trigger('cart:updated', [cartData]);
            jQuery(document).trigger('ajaxCart.afterCartLoad');
          }
          
          // Add success animation to button
          button.classList.add('t4s-btn-added', 'is-added');
          setTimeout(() => {
            button.classList.remove('t4s-btn-added', 'is-added');
          }, 2000);
          
          // Open cart drawer - try Dawn first, then Kalles
          setTimeout(() => {
            // Try Dawn cart-drawer (Web Component with open method)
            const dawnCartDrawer = document.querySelector('cart-drawer');
            if (dawnCartDrawer && typeof dawnCartDrawer.open === 'function') {
              console.log('DEBUG: Opening Dawn cart-drawer');
              dawnCartDrawer.open();
            } else {
              // Try clicking cart icon (Dawn alternative)
              const cartIcon = document.querySelector('#cart-icon-bubble');
              if (cartIcon) {
                console.log('DEBUG: Clicking Dawn cart icon');
                cartIcon.click();
              } else {
                // Fallback to Kalles drawer
                const kallesTrigger = document.querySelector('[data-drawer-options*="t4s-mini_cart"]');
                if (kallesTrigger) {
                  console.log('DEBUG: Opening Kalles mini cart');
                  kallesTrigger.click();
                } else {
                  // Manual fallback for Kalles
                  const kallesMiniCart = document.getElementById('t4s-mini_cart');
                  if (kallesMiniCart) {
                    kallesMiniCart.classList.remove('t4s-dn');
                    kallesMiniCart.classList.add('is--open');
                    kallesMiniCart.removeAttribute('aria-hidden');
                    document.documentElement.classList.add('is--opend-drawer');
                    document.body.classList.add('t4s-drawer-open');
                  }
                }
              }
            }
          }, 200);
          
          console.log('DEBUG: Cart updated and cart drawer opened');
        })
        .catch(error => {
          console.error('Error adding items:', error);
          alert('Erro ao adicionar ao carrinho. Por favor, tente novamente.');
        })
        .finally(() => {
          // Remove loading state
          button.classList.remove('loading', 'is-loading', 't4s-btn-loading');
          button.removeAttribute('aria-busy');
          button.removeAttribute('aria-disabled');
          button.disabled = false;
          
          // Hide spinner
          const loadingSpinner = button.querySelector('.t4s-loading__spinner, .t4s-cart-spinner');
          if (loadingSpinner) loadingSpinner.setAttribute('hidden', '');
          
          // Remove added spinner
          const addedSpinner = button.querySelector('.t4s-loading__spinner:not([hidden])');
          if (addedSpinner && addedSpinner.parentNode === button) {
            // Keep the spinner but hide it
          }
          
          isAddingPatches = false;
        });
        
        return false;
      }
      
      // Wait for DOM to be ready and theme to initialize
      function attachListeners() {
        // Attach click listeners to all add to cart buttons (Dawn + Kalles/T4S selectors)
        const buttons = document.querySelectorAll(
          'button[data-atc-form], ' +
          'button[data-action-atc], ' +
          'button[type="submit"][name="add"], ' +
          'button[type="submit"][name="add1"], ' +
          '.t4s-product-form__submit, ' +
          '.t4s-sticky-atc__atc, ' +
          'product-form button[type="submit"], ' +
          '.product-form__submit, ' +
          '.shopify-payment-button button'
        );
        
        console.log('DEBUG: Found', buttons.length, 'add to cart buttons');
        
        buttons.forEach(button => {
          if (!button.dataset.patchListenerAdded) {
            button.dataset.patchListenerAdded = 'true';
            // Add click listener with capture phase to run before theme
            button.addEventListener('click', handleAddToCartClick, true);
          }
        });
      }
      
      // Try to attach immediately
      attachListeners();
      
      // Also attach after a short delay to catch dynamically added buttons
      setTimeout(attachListeners, 100);
      setTimeout(attachListeners, 500);
      setTimeout(attachListeners, 1000);
      
      // Listen for dynamically added buttons
      const observer = new MutationObserver(function(mutations) {
        mutations.forEach(function(mutation) {
          mutation.addedNodes.forEach(function(node) {
            if (node.nodeType === 1) {
              const buttons = node.querySelectorAll && node.querySelectorAll(
                'button[data-atc-form], ' +
                'button[data-action-atc], ' +
                'button[type="submit"][name="add"], ' +
                '.t4s-product-form__submit, ' +
                '.t4s-sticky-atc__atc, ' +
                'product-form button[type="submit"], ' +
                '.product-form__submit'
              );
              if (buttons && buttons.length > 0) {
                buttons.forEach(button => {
                  if (!button.dataset.patchListenerAdded) {
                    button.dataset.patchListenerAdded = 'true';
                    button.addEventListener('click', handleAddToCartClick, true);
                  }
                });
              }
            }
          });
        });
      });
      
      observer.observe(document.body, {
        childList: true,
        subtree: true
      });
    }
    
    
    // Club to league mapping based on simplified names
    const clubToLeagueMap = {
      // Premier League
      'arsenal': 'premier-league',
      'aston villa': 'premier-league',
      'bournemouth': 'premier-league',
