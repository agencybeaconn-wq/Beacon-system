    // Champions League specific club patches (order matters - more specific first)
    const championsLeagueClubPatches = {
      'eintracht frankfurt': 'patch-champions-league',
      'atletico madrid': 'patch-champions-league',
      'borussia dortmund': 'patch-champions-league',
      'bayer leverkusen': 'patch-champions-league',
