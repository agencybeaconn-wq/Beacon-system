<script>
  window.customPlayerRules = [
    {%- for block in section.blocks -%}
      {
        keywords: "{{ block.settings.keywords | downcase }}",
        excludeKeywords: "{{ block.settings.exclude_keywords | downcase }}",
        playerData: `
          {%- capture player_list -%}
            {%- for i in (1..15) -%}
              {%- assign name_key = 'player_name_' | append: i -%}
              {%- assign num_key = 'player_number_' | append: i -%}
              {%- assign p_name = block.settings[name_key] -%}
              {%- assign p_num = block.settings[num_key] -%}
              {%- if p_name != blank -%}
                {{ p_name }}|{{ p_num }}
                {%- unless forloop.last -%}\n{%- endunless -%}
              {%- endif -%}
            {%- endfor -%}
          {%- endcapture -%}
          {{ player_list | strip | strip_newlines }}
        `
      }{% unless forloop.last %},{% endunless %}
    {%- endfor -%}
  ];
</script>

{% schema %}
{
  "name": "Configuração de Jogadores",
  "settings": [
    {
      "type": "paragraph",
      "content": "Configure listas de jogadores que aparecerão na customização baseadas no título do produto."
    }
  ],
  "blocks": [
    {
      "type": "player_rule",
      "name": "Regra de Jogadores",
      "settings": [
        {
          "type": "textarea",
          "id": "keywords",
          "label": "Palavras-chave (separadas por vírgula)",
          "info": "Ex: flamengo, liverpool"
        },
        {
          "type": "textarea",
          "id": "exclude_keywords",
          "label": "Palavras-chave para Exclusão",
          "info": "Ex: treino, camisa 2"
        },
        { "type": "header", "content": "Jogador 1" },
        { "type": "text", "id": "player_name_1", "label": "Nome" },
        { "type": "text", "id": "player_number_1", "label": "Número" },
        { "type": "header", "content": "Jogador 2" },
