# --- Shopify Admin API access tokens, one per configured shop ---
# Name pattern: SHOPIFY_<ALIAS>_TOKEN — alias matches shops.json keys (UPPER_SNAKE).
SHOPIFY_KRON_WATCHES_TOKEN=shpat_replace_me
SHOPIFY_SUPREMO_TOKEN=shpat_replace_me
SHOPIFY_FG_TOKEN=shpat_replace_me

# --- Per-user API keys for HTTP transport (Bearer auth) ---
# Name pattern: LEVER_MCP_API_KEY_<USER> — value is a random secret string.
# Generate with: openssl rand -hex 32  (or any password manager)
# Each Lever collaborator gets their own key. Revoke by removing the env var.
LEVER_MCP_API_KEY_JOAO=replace_with_long_random_string
LEVER_MCP_API_KEY_PEDRO=replace_with_long_random_string
LEVER_MCP_API_KEY_WESLEY=replace_with_long_random_string
LEVER_MCP_API_KEY_FELIPE=replace_with_long_random_string

# --- Optional: override path to shops.json ---
# Defaults: file next to dist/ → file in cwd. Set this for Vercel if needed.
# SHOPIFY_MCP_CONFIG=/var/task/shops.json
