{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "outputDirectory": "dist",
  "functions": {
    "api/mcp.ts": { "maxDuration": 30 },
    "api/oauth/authorize.ts": { "maxDuration": 15 },
    "api/oauth/token.ts": { "maxDuration": 15 },
    "api/oauth/register.ts": { "maxDuration": 10 },
    "api/well-known/oauth-protected-resource.ts": { "maxDuration": 5 },
    "api/well-known/oauth-authorization-server.ts": { "maxDuration": 5 },
    "api/lever-logo.ts": { "maxDuration": 5 },
    "api/manifest.ts": { "maxDuration": 5 }
  },
  "rewrites": [
    { "source": "/", "destination": "/api/mcp" },
    { "source": "/mcp", "destination": "/api/mcp" },
    { "source": "/lever-logo.png", "destination": "/api/lever-logo" },
    { "source": "/favicon.ico", "destination": "/api/lever-logo" },
    { "source": "/manifest.json", "destination": "/api/manifest" },
    { "source": "/.well-known/oauth-protected-resource", "destination": "/api/well-known/oauth-protected-resource" },
    { "source": "/.well-known/oauth-authorization-server", "destination": "/api/well-known/oauth-authorization-server" },
    { "source": "/oauth/register", "destination": "/api/oauth/register" },
    { "source": "/oauth/authorize", "destination": "/api/oauth/authorize" },
    { "source": "/oauth/token", "destination": "/api/oauth/token" }
  ]
}
